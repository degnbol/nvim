import gudhi._simplex_tree_ext
import gudhi._simplex_tree_ext as t
import np
from _typeshed import Incomplete
from typing import ArrayLike

class SimplexTree(gudhi._simplex_tree_ext._Simplex_tree_python_interface):
    def __init__(self, other: Incomplete | None = ...) -> None: ...
    def copy(self) -> SimplexTree: ...
    def __deepcopy__(self) -> SimplexTree: ...
    def initialize_filtration(self): ...
    @staticmethod
    def create_from_array(filtrations, max_filtration: float = ...) -> SimplexTree: ...
    def insert_edges_from_coo_matrix(self, edges) -> SimplexTree: ...
    def insert_batch(self, vertex_array: ArrayLike, filtrations: ArrayLike) -> SimplexTree: ...
    def extended_persistence(self, homology_coeff_field: int = ..., min_persistence: int = ...) -> list[list[tuple[int, tuple[float, float]]]]: ...
    def persistence(self, homology_coeff_field: int = ..., min_persistence: int = ..., persistence_dim_max: bool = ...) -> list[tuple[int, tuple[float, float]]]: ...
    def compute_persistence(self, homology_coeff_field: int = ..., min_persistence: int = ..., persistence_dim_max: bool = ...) -> SimplexTree: ...
    def betti_numbers(self) -> list[int]: ...
    def persistent_betti_numbers(self, from_value, to_value) -> list[int]: ...
    def persistence_intervals_in_dimension(self, dimension) -> np.ndarray: ...
    def persistence_pairs(self) -> list[tuple[list[int], list[int]]]: ...
    def write_persistence_diagram(self, persistence_file) -> SimplexTree: ...
    def lower_star_persistence_generators(self) -> tuple[list[np.ndarray], list[np.ndarray]]: ...
    def flag_persistence_generators(self) -> tuple[np.ndarray, list[np.ndarray], np.ndarray, list[np.ndarray]]: ...
    def collapse_edges(self, nb_iterations: int = ...) -> SimplexTree: ...
