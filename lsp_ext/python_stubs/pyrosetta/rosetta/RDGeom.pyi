import pyrosetta.rosetta.RDNumeric
import typing
from typing import overload

class Point:
    def __init__(self, *args, **kwargs) -> None: ...
    def assign(self) -> Point: ...
    def copy(self) -> Point: ...
    @overload
    def dimension(self) -> int: ...
    @overload
    def dimension(self) -> unsignedint: ...
    @overload
    def length(self) -> float: ...
    @overload
    def length(self) -> double: ...
    @overload
    def lengthSq(self) -> float: ...
    @overload
    def lengthSq(self) -> double: ...
    @overload
    def normalize(self) -> None: ...
    @overload
    def normalize(self) -> void: ...
    def __getitem__(self, i: int) -> float: ...
    def __iter__(self) -> typing.Iterator[float]: ...

class Point3D(Point):
    x: float
    y: float
    z: float
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, xv: float, yv: float, zv: float) -> None: ...
    @overload
    def __init__(self, arg0: Point3D) -> None: ...
    @overload
    def __init__(self, arg0: Point3D) -> None: ...
    @overload
    def angleTo(self, other: Point3D) -> float: ...
    @overload
    def angleTo(self, constclassRDGeom) -> double: ...
    def assign(self, other: Point3D) -> Point3D: ...
    def copy(self) -> Point: ...
    def crossProduct(self, other: Point3D) -> Point3D: ...
    @overload
    def dimension(self) -> int: ...
    @overload
    def dimension(self) -> unsignedint: ...
    def directionVector(self, other: Point3D) -> Point3D: ...
    @overload
    def dotProduct(self, other: Point3D) -> float: ...
    @overload
    def dotProduct(self, constclassRDGeom) -> double: ...
    def getPerpendicular(self) -> Point3D: ...
    @overload
    def length(self) -> float: ...
    @overload
    def length(self) -> double: ...
    @overload
    def lengthSq(self) -> float: ...
    @overload
    def lengthSq(self) -> double: ...
    @overload
    def normalize(self) -> None: ...
    @overload
    def normalize(self) -> void: ...
    @overload
    def signedAngleTo(self, other: Point3D) -> float: ...
    @overload
    def signedAngleTo(self, constclassRDGeom) -> double: ...
    def __getitem__(self, i: int) -> float: ...
    def __iter__(self) -> typing.Iterator[float]: ...
    def __iadd__(self, other: Point3D) -> Point3D: ...
    def __imul__(self, scale: float) -> Point3D: ...
    def __isub__(self, other: Point3D) -> Point3D: ...
    def __itruediv__(self, scale: float) -> Point3D: ...
    def __neg__(self) -> Point3D: ...

class Transform3D(pyrosetta.rosetta.RDNumeric.SquareMatrix_double_t):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: Transform3D) -> None: ...
    @overload
    def __init__(self, arg0: Transform3D) -> None: ...
    @overload
    def Reflect(self) -> None: ...
    @overload
    def Reflect(self) -> void: ...
    @overload
    def SetRotation(self, angle: float, axis) -> None: ...
    @overload
    def SetRotation(self, double, RDGeom) -> void: ...
    @overload
    def SetRotation(self, angle: float, axis: Point3D) -> None: ...
    @overload
    def SetRotation(self, double, constclassRDGeom) -> void: ...
    @overload
    def SetRotation(self, cosT: float, sinT: float, axis: Point3D) -> None: ...
    @overload
    def SetTranslation(self, move: Point3D) -> None: ...
    @overload
    def SetTranslation(self, constclassRDGeom) -> void: ...
    @overload
    def TransformPoint(self, pt: Point3D) -> None: ...
    @overload
    def TransformPoint(self, classRDGeom) -> void: ...
    @overload
    def setToIdentity(self) -> None: ...
    @overload
    def setToIdentity(self) -> void: ...
