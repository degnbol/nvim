from typing import overload

class Stringifier:
    def __init__(self, arg0: Stringifier) -> None: ...
    def assign(self) -> Stringifier: ...
    def get_string(self) -> str: ...

class Stringy:
    @overload
    def __init__(self, _in: str) -> None: ...
    @overload
    def __init__(self, _in: str) -> None: ...
    @overload
    def __init__(self, arg0: Stringy) -> None: ...
    def assign(self) -> Stringy: ...
    def get_string(self) -> str: ...
