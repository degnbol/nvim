    def index_to_vd(self) -> pyrosetta.rosetta.core.chemical.AtomRefMapping_unsigned_long_void__star__t: ...
    def vd_to_index(self) -> pyrosetta.rosetta.core.chemical.AtomRefMapping_void__star__unsigned_long_t: ...

class RestypeToRDMolOptions:
    aro2double: bool
    keep_hydro: bool
    neutralize: bool
    noImplicitHs: bool
    sanitize: bool
    skipHs: bool
    @overload
    def __init__(self, arg0: RestypeToRDMolOptions) -> None: ...
    @overload
    def __init__(self) -> None: ...
    def assign(self) -> RestypeToRDMolOptions: ...

