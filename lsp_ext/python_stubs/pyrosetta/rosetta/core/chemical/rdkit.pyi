    def __init__(self, res: pyrosetta.rosetta.core.chemical.MutableResidueType) -> None: ...
    @overload
    def __init__(self, res: pyrosetta.rosetta.core.chemical.MutableResidueType, neutralize: bool) -> None: ...
    @overload
    def __init__(self, res: pyrosetta.rosetta.core.chemical.MutableResidueType, neutralize: bool, keep_hydro: bool) -> None: ...
    @overload
    def __init__(self, res: pyrosetta.rosetta.core.chemical.MutableResidueType, neutralize: bool, keep_hydro: bool, sanitize: bool) -> None: ...
    @overload
    def __init__(self, res: pyrosetta.rosetta.core.chemical.MutableResidueType, neutralize: bool, keep_hydro: bool, sanitize: bool, noImplicitHs: bool) -> None: ...
    @overload
    def __init__(self, res: pyrosetta.rosetta.core.chemical.MutableResidueType, neutralize: bool, keep_hydro: bool, sanitize: bool, noImplicitHs: bool, skipHs: bool) -> None: ...
    @overload
    def __init__(self, res: pyrosetta.rosetta.core.chemical.MutableResidueType, options: RestypeToRDMolOptions) -> None: ...
    @overload
    def __init__(self, arg0: RestypeToRDMol) -> None: ...
