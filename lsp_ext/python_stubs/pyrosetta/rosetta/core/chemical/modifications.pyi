from typing import ClassVar, overload

FAIL_BAD_INPUT: ChemistryStatus
FAIL_BAD_SETTINGS: ChemistryStatus
FAIL_DO_NOT_RETRY: ChemistryStatus
FAIL_RETRY: ChemistryStatus
SUCCESS: ChemistryStatus

class ChemistryBase:
    @overload
    def __init__(self, name: str) -> None: ...
    @overload
    def __init__(self, arg0: ChemistryBase) -> None: ...
    @overload
    def apply(self) -> None: ...
    @overload
    def apply(self, classcore) -> void: ...
    def assign(self) -> ChemistryBase: ...
    def get_additional_output(self) -> pyrosetta.rosetta.core.chemical.MutableResidueType: ...
    def get_last_status(self) -> ChemistryStatus: ...
    def get_mapping(self) -> pyrosetta.rosetta.core.chemical.AtomRefMapping_void__star__void__star__t: ...
    @overload
    def has_additional_output(self) -> bool: ...
    @overload
    def has_additional_output(self) -> bool: ...
    def name(self) -> str: ...
    @overload
    def set_last_status(self, setting: ChemistryStatus) -> None: ...
    @overload
    def set_last_status(self, enumcore) -> void: ...

class ChemistryStatus:
    __members__: ClassVar[dict] = ...  # read-only
    FAIL_BAD_INPUT: ClassVar[ChemistryStatus] = ...
    FAIL_BAD_SETTINGS: ClassVar[ChemistryStatus] = ...
    FAIL_DO_NOT_RETRY: ClassVar[ChemistryStatus] = ...
    FAIL_RETRY: ClassVar[ChemistryStatus] = ...
    SUCCESS: ClassVar[ChemistryStatus] = ...
    __entries: ClassVar[dict] = ...
    def __init__(self, value: int) -> None: ...
    def __and__(self, other: object) -> object: ...
    def __eq__(self, other: object) -> bool: ...
    def __ge__(self, other: object) -> bool: ...
    def __gt__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def __index__(self) -> int: ...
    def __int__(self) -> int: ...
    def __invert__(self) -> object: ...
    def __le__(self, other: object) -> bool: ...
    def __lt__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __or__(self, other: object) -> object: ...
    def __rand__(self, other: object) -> object: ...
    def __ror__(self, other: object) -> object: ...
    def __rxor__(self, other: object) -> object: ...
    def __xor__(self, other: object) -> object: ...
    @property
    def name(self) -> str: ...
    @property
    def value(self) -> int: ...

class Reprotonate(ChemistryBase):
    def __init__(self) -> None: ...
    @overload
    def apply(self, res: pyrosetta.rosetta.core.chemical.MutableResidueType) -> None: ...
    @overload
    def apply(self, classcore) -> void: ...
    def assign(self) -> Reprotonate: ...
    @staticmethod
    def class_name() -> str: ...
    def get_mapping(self) -> pyrosetta.rosetta.core.chemical.AtomRefMapping_void__star__void__star__t: ...

