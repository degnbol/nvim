class EnzymeData:
    atom_to_modify: str
    consensus_residues: pyrosetta.rosetta.utility.vector1_utility_vector1_std_string_t
    consensus_sequence: str
    cs_resnum: int
    cs_type: ConsensusSequenceType
    efficiency: float
    second_substrates_or_byproducts: pyrosetta.rosetta.utility.vector1_std_string
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: EnzymeData) -> None: ...
    def assign(self) -> EnzymeData: ...

class EnzymeManager(pyrosetta.rosetta.utility.SingletonBase_core_enzymes_EnzymeManager_t):
    def __init__(self, *args, **kwargs) -> None: ...
    @staticmethod
    def get_consensus_residues(family: str, species: str, enzyme: str) -> pyrosetta.rosetta.utility.vector1_utility_vector1_std_string_t: ...
    @staticmethod
    def get_consensus_sequence(family: str, species: str, enzyme: str) -> str: ...
    @staticmethod
    def get_consensus_sequence_type(family: str, species: str, enzyme: str) -> ConsensusSequenceType: ...
    @staticmethod
    def get_efficiency(family: str, species: str, enzyme: str) -> float: ...
    @staticmethod
    def get_reactive_atom(family: str, species: str, enzyme: str) -> str: ...
    @staticmethod
    def get_reactive_residue_consensus_sequence_position(family: str, species: str, enzyme: str) -> int: ...
    @staticmethod
    def get_second_substrates_or_byproducts(family: str, species: str, enzyme: str) -> pyrosetta.rosetta.utility.vector1_std_string: ...

