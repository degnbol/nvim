import pyrosetta.rosetta.basic
import pyrosetta.rosetta.cereal
import pyrosetta.rosetta.core.pose
from . import simple_calculators as simple_calculators
from typing import overload

class CalculatorFactory:
    def __init__(self, *args, **kwargs) -> None: ...
    @staticmethod
    def Instance() -> CalculatorFactory: ...
    @overload
    def check_calculator_exists(self, calculator_name: str) -> bool: ...
    @overload
    def check_calculator_exists(self, conststd) -> bool: ...
    @overload
    def clear_calculators(self) -> bool: ...
    @overload
    def clear_calculators(self) -> bool: ...
    @overload
    def register_calculator(self, calculator_name: str, new_calculator) -> None: ...
    @overload
    def register_calculator(self, conststd, constclassstd) -> void: ...
    @overload
    def remove_calculator(self, calculator_name: str) -> bool: ...
    @overload
    def remove_calculator(self, conststd) -> bool: ...
    def retrieve_calculator(self, *args, **kwargs): ...

class EnergyDependentCalculator(PoseMetricCalculator):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: EnergyDependentCalculator) -> None: ...
    def assign(self) -> EnergyDependentCalculator: ...
    @overload
    def get(self, key: str, val: pyrosetta.rosetta.basic.MetricValueBase, this_pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def get(self, conststd, classbasic, constclasscore) -> void: ...
    @overload
    def get(self, key: str, this_pose: pyrosetta.rosetta.core.pose.Pose) -> str: ...
    @overload
    def load(self, arc: pyrosetta.rosetta.cereal.BinaryInputArchive) -> None: ...
    @overload
    def load(self, classcereal) -> void: ...
    @overload
    def notify_energy_change(self) -> None: ...
    @overload
    def notify_energy_change(self) -> void: ...
    @overload
    def save(self, arc: pyrosetta.rosetta.cereal.BinaryOutputArchive) -> None: ...
    @overload
    def save(self, classcereal) -> void: ...

