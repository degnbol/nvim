import pyrosetta.rosetta.core.pose
from typing import overload

class ConformationEvent(GeneralEvent):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def __init__(self, arg0: ConformationEvent) -> None: ...
    def assign(self, rval: ConformationEvent) -> ConformationEvent: ...

class DestructionEvent:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def __init__(self, arg0: DestructionEvent) -> None: ...
    def assign(self, rval: DestructionEvent) -> DestructionEvent: ...

class EnergyEvent(GeneralEvent):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def __init__(self, arg0: EnergyEvent) -> None: ...
    def assign(self, rval: EnergyEvent) -> EnergyEvent: ...

class GeneralEvent:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def __init__(self, arg0: GeneralEvent) -> None: ...
    def assign(self, rval: GeneralEvent) -> GeneralEvent: ...
    def getPose(self) -> pyrosetta.rosetta.core.pose.Pose: ...
