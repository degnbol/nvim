import pyrosetta.rosetta.core.conformation
import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.core.scoring
import pyrosetta.rosetta.core.scoring.methods
import pyrosetta.rosetta.utility
from typing import overload

class symECreator(pyrosetta.rosetta.core.scoring.methods.EnergyMethodCreator):
    def __init__(self) -> None: ...
    def assign(self) -> symECreator: ...
    def create_energy_method(self) -> pyrosetta.rosetta.core.scoring.methods.EnergyMethod: ...
    def score_types_for_method(self) -> pyrosetta.rosetta.utility.vector1_core_scoring_ScoreType: ...

class symEnergy(pyrosetta.rosetta.core.scoring.methods.ContextDependentLRTwoBodyEnergy):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: symEnergy) -> None: ...
    @overload
    def __init__(self, arg0: symEnergy) -> None: ...
    def assign(self) -> symEnergy: ...
    def clone(self) -> pyrosetta.rosetta.core.scoring.methods.EnergyMethod: ...
    @overload
    def defines_intrares_energy(self, weights: pyrosetta.rosetta.core.scoring.EMapVector) -> bool: ...
    @overload
    def defines_intrares_energy(self, constclasscore) -> bool: ...
    def defines_residue_pair_energy(self, pose: pyrosetta.rosetta.core.pose.Pose, res1: int, res2: int) -> bool: ...
    def eval_intrares_energy(self, rsd: pyrosetta.rosetta.core.conformation.Residue, pose: pyrosetta.rosetta.core.pose.Pose, sfxn: pyrosetta.rosetta.core.scoring.ScoreFunction, emap: pyrosetta.rosetta.core.scoring.EMapVector) -> None: ...
    @overload
    def indicate_required_context_graphs(self, context_graphs_required: pyrosetta.rosetta.utility.vector1_bool) -> None: ...
    @overload
    def indicate_required_context_graphs(self, classutility) -> void: ...
    def long_range_type(self) -> pyrosetta.rosetta.core.scoring.methods.LongRangeEnergyType: ...
    def residue_pair_energy(self, rsd1: pyrosetta.rosetta.core.conformation.Residue, rsd2: pyrosetta.rosetta.core.conformation.Residue, pose: pyrosetta.rosetta.core.pose.Pose, emap: pyrosetta.rosetta.core.scoring.EMapVector) -> None: ...
    def setup_for_packing(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def setup_for_scoring(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def setup_for_scoring(self, classcore, constclasscore) -> void: ...
    @overload
    def version(self) -> int: ...
    @overload
    def version(self) -> unsignedlong: ...
