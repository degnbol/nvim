from typing import overload

class AtomicDepth:
    @overload
    def __init__(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def __init__(self, pose: pyrosetta.rosetta.core.pose.Pose, probe_radius: float) -> None: ...
    @overload
    def __init__(self, pose: pyrosetta.rosetta.core.pose.Pose, probe_radius: float, poly_leu_depth: bool) -> None: ...
    @overload
    def __init__(self, pose: pyrosetta.rosetta.core.pose.Pose, probe_radius: float, poly_leu_depth: bool, resolution: float) -> None: ...
    @overload
    def __init__(self, arg0: AtomicDepth) -> None: ...
    def assign(self) -> AtomicDepth: ...
    @overload
    def calcdepth(self, atoms: pyrosetta.rosetta.utility.vector1_core_conformation_Atom, type_set: pyrosetta.rosetta.core.chemical.AtomTypeSet) -> pyrosetta.rosetta.utility.vector1_double: ...
    @overload
    def calcdepth(self, atom: pyrosetta.rosetta.core.conformation.Atom, type_set: pyrosetta.rosetta.core.chemical.AtomTypeSet) -> float: ...
    @overload
    def visualize_at_depth(self, depth: float, fname: str) -> None: ...
    @overload
    def visualize_at_depth(self, depth: float, fname: str, fraction: float) -> None: ...

class point3d:
    x: float
    y: float
    z: float
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: point3d) -> None: ...
    def assign(self) -> point3d: ...

class volumepixel:
    distance: float
    inout: bool
    isbound: bool
    isdone: bool
    def __init__(self) -> None: ...

class voxel:
    ix: int
    iy: int
    iz: int
    def __init__(self) -> None: ...

class voxel2:
    ix: int
    iy: int
    iz: int
    def __init__(self) -> None: ...

