import pyrosetta.rosetta.core.chemical
import pyrosetta.rosetta.core.conformation
import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.core.scoring
import pyrosetta.rosetta.core.scoring.methods
import pyrosetta.rosetta.utility
from typing import overload

class DDPlookup:
    @overload
    def __init__(self, filename: str) -> None: ...
    @overload
    def __init__(self, arg0: DDPlookup) -> None: ...
    def assign(self) -> DDPlookup: ...
    def get_potentials(self, aa1: pyrosetta.rosetta.core.chemical.AA, aa2: pyrosetta.rosetta.core.chemical.AA, distance: float) -> float: ...

class DDPscore(pyrosetta.rosetta.core.scoring.methods.ContextDependentTwoBodyEnergy):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: DDPscore) -> None: ...
    @overload
    def __init__(self, arg0: DDPscore) -> None: ...
    @overload
    def atomic_interaction_cutoff(self) -> float: ...
    @overload
    def atomic_interaction_cutoff(self) -> double: ...
    def clone(self) -> pyrosetta.rosetta.core.scoring.methods.EnergyMethod: ...
    @overload
    def defines_intrares_energy(self) -> bool: ...
    @overload
    def defines_intrares_energy(self, constclasscore) -> bool: ...
    def eval_intrares_energy(self) -> None: ...
    @overload
    def indicate_required_context_graphs(self, context_graphs_required: pyrosetta.rosetta.utility.vector1_bool) -> None: ...
    @overload
    def indicate_required_context_graphs(self, classutility) -> void: ...
    def residue_pair_energy(self, rsd1: pyrosetta.rosetta.core.conformation.Residue, rsd2: pyrosetta.rosetta.core.conformation.Residue, pose: pyrosetta.rosetta.core.pose.Pose, sfxn: pyrosetta.rosetta.core.scoring.ScoreFunction, emap: pyrosetta.rosetta.core.scoring.EMapVector) -> None: ...
    @overload
    def setup_for_derivatives(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def setup_for_derivatives(self, classcore, constclasscore) -> void: ...
    def setup_for_packing(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def setup_for_scoring(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def setup_for_scoring(self, classcore, constclasscore) -> void: ...

class DDPscoreCreator(pyrosetta.rosetta.core.scoring.methods.EnergyMethodCreator):
    def __init__(self) -> None: ...
    def assign(self) -> DDPscoreCreator: ...
    def create_energy_method(self) -> pyrosetta.rosetta.core.scoring.methods.EnergyMethod: ...
    def score_types_for_method(self) -> pyrosetta.rosetta.utility.vector1_core_scoring_ScoreType: ...
