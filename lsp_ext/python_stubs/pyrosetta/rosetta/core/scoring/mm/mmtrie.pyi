import pyrosetta.rosetta.cereal
import pyrosetta.rosetta.core.conformation
import pyrosetta.rosetta.std
from typing import overload

class MMEnergyTableAtom(pyrosetta.rosetta.core.conformation.Atom):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, res: pyrosetta.rosetta.core.conformation.Residue, mm_atom_index: int) -> None: ...
    @overload
    def __init__(self, arg0: MMEnergyTableAtom) -> None: ...
    def assign(self) -> MMEnergyTableAtom: ...
    @overload
    def is_hydrogen(self) -> bool: ...
    @overload
    def is_hydrogen(self) -> bool: ...
    @overload
    def is_hydrogen(self, setting: bool) -> None: ...
    @overload
    def is_hydrogen(self, bool) -> void: ...
    @overload
    def is_wat(self) -> bool: ...
    @overload
    def is_wat(self) -> bool: ...
    @overload
    def is_wat(self, setting: bool) -> None: ...
    @overload
    def is_wat(self, bool) -> void: ...
    @overload
    def load(self, arc: pyrosetta.rosetta.cereal.BinaryInputArchive) -> None: ...
    @overload
    def load(self, classcereal) -> void: ...
    @overload
    def mm_atom_type(self) -> int: ...
    @overload
    def mm_atom_type(self) -> unsignedlong: ...
    @overload
    def mm_atom_type(self, setting: int) -> None: ...
    @overload
    def mm_atom_type(self, unsignedlong) -> void: ...
    @overload
    def print(self) -> None: ...
    @overload
    def print(self) -> void: ...
    @overload
    def print(self, os: pyrosetta.rosetta.std.ostream) -> None: ...
    @overload
    def print(self, std) -> void: ...
    @overload
    def save(self, arc: pyrosetta.rosetta.cereal.BinaryOutputArchive) -> None: ...
    @overload
    def save(self, classcereal) -> void: ...
    def __eq__(self, other: MMEnergyTableAtom) -> bool: ...
