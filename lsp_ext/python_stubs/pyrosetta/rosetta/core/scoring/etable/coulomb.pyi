import pyrosetta.rosetta.core.scoring.methods
import pyrosetta.rosetta.numeric
from typing import overload

class Coulomb:
    @overload
    def __init__(self, options: pyrosetta.rosetta.core.scoring.methods.EnergyMethodOptions) -> None: ...
    @overload
    def __init__(self, arg0: Coulomb) -> None: ...
    def assign(self) -> Coulomb: ...
    def clone(self) -> Coulomb: ...
    @overload
    def die(self) -> float: ...
    @overload
    def die(self) -> double: ...
    @overload
    def eval_atom_atom_fa_elecE(self, i_xyz: pyrosetta.rosetta.numeric.xyzVector_double_t, i_charge: float, j_xyz: pyrosetta.rosetta.numeric.xyzVector_double_t, j_charge: float) -> float: ...
    @overload
    def eval_atom_atom_fa_elecE(self, i_xyz: pyrosetta.rosetta.numeric.xyzVector_double_t, i_charge: float, j_xyz: pyrosetta.rosetta.numeric.xyzVector_double_t, j_charge: float, d2: float) -> float: ...
    def eval_dfa_elecE_dr_over_r(self, dis2: float, q1: float, q2: float) -> float: ...
    @overload
    def initialize(self) -> None: ...
    @overload
    def initialize(self) -> void: ...
    @overload
    def max_dis(self) -> float: ...
    @overload
    def max_dis(self) -> double: ...
    @overload
    def max_dis2(self) -> float: ...
    @overload
    def max_dis2(self) -> double: ...
    @overload
    def min_dis(self) -> float: ...
    @overload
    def min_dis(self) -> double: ...
    @overload
    def min_dis2(self) -> float: ...
    @overload
    def min_dis2(self) -> double: ...
    @overload
    def no_dis_dep_die(self) -> bool: ...
    @overload
    def no_dis_dep_die(self) -> bool: ...
    def set_sigmoidal_die(self, setting: bool) -> None: ...
    @overload
    def sigmoid_deps_dr(self, R: float) -> float: ...
    @overload
    def sigmoid_deps_dr(self, double) -> double: ...
    @overload
    def sigmoid_eps(self, R: float) -> float: ...
    @overload
    def sigmoid_eps(self, double) -> double: ...
    @overload
    def smooth_fa_elec(self) -> bool: ...
    @overload
    def smooth_fa_elec(self) -> bool: ...
