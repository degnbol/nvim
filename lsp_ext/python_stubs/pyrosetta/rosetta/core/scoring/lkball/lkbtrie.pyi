import pyrosetta.rosetta.cereal
import pyrosetta.rosetta.core.conformation
import pyrosetta.rosetta.core.scoring.etable
import pyrosetta.rosetta.core.scoring.lkball
import pyrosetta.rosetta.numeric
import pyrosetta.rosetta.std
import pyrosetta.rosetta.utility
from typing import overload

class LKBAtom:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: LKBAtom) -> None: ...
    def assign(self) -> LKBAtom: ...
    @overload
    def atom(self) -> pyrosetta.rosetta.core.conformation.Atom: ...
    @overload
    def atom(self, base: pyrosetta.rosetta.core.conformation.Atom) -> None: ...
    @overload
    def atom(self, constclasscore) -> void: ...
    @overload
    def atom_weights(self) -> pyrosetta.rosetta.utility.fixedsizearray1_double_2UL_t: ...
    @overload
    def atom_weights(self, atom_weights: pyrosetta.rosetta.utility.fixedsizearray1_double_2UL_t) -> None: ...
    @overload
    def is_hydrogen(self) -> bool: ...
    @overload
    def is_hydrogen(self) -> bool: ...
    @overload
    def load(self, arc: pyrosetta.rosetta.cereal.BinaryInputArchive) -> None: ...
    @overload
    def load(self, classcereal) -> void: ...
    @overload
    def n_attached_waters(self) -> int: ...
    @overload
    def n_attached_waters(self) -> unsignedlong: ...
    @overload
    def print(self) -> None: ...
    @overload
    def print(self) -> void: ...
    @overload
    def print(self, os: pyrosetta.rosetta.std.ostream) -> None: ...
    @overload
    def print(self, std) -> void: ...
    @overload
    def save(self, arc: pyrosetta.rosetta.cereal.BinaryOutputArchive) -> None: ...
    @overload
    def save(self, classcereal) -> void: ...
    @overload
    def waters(self) -> pyrosetta.rosetta.utility.vector1_numeric_xyzVector_double_t: ...
    @overload
    def waters(self, n_attached: int, offset: int, waters: pyrosetta.rosetta.utility.vector1_numeric_xyzVector_double_t) -> None: ...
    @overload
    def xyz(self) -> pyrosetta.rosetta.numeric.xyzVector_double_t: ...
    @overload
    def xyz(self, base: pyrosetta.rosetta.numeric.xyzVector_double_t) -> None: ...
    @overload
    def xyz(self, constclassnumeric) -> void: ...
    def __eq__(self, other: LKBAtom) -> bool: ...

class LKBTrieEvaluator:
    @overload
    def __init__(self, wt_lk_ball: float, wt_lk_ball_iso: float, wt_lk_ball_wtd: float, wt_lk_ball_bridge: float, wt_lk_ball_bridge_uncpl: float, lkb: pyrosetta.rosetta.core.scoring.lkball.LK_BallEnergy, etable: pyrosetta.rosetta.core.scoring.etable.Etable) -> None: ...
    @overload
    def __init__(self, arg0: LKBTrieEvaluator) -> None: ...
    def heavyatom_heavyatom_energy(self, at1: LKBAtom, at2: LKBAtom, d2: float) -> float: ...
    def heavyatom_hydrogenatom_energy(self) -> float: ...
    @overload
    def hydrogen_interaction_cutoff2(self) -> float: ...
    @overload
    def hydrogen_interaction_cutoff2(self) -> double: ...
    def hydrogenatom_heavyatom_energy(self) -> float: ...
    def hydrogenatom_hydrogenatom_energy(self) -> float: ...
