import pyrosetta.rosetta.cereal
import pyrosetta.rosetta.core.conformation
import pyrosetta.rosetta.core.scoring.elec
import pyrosetta.rosetta.numeric
import pyrosetta.rosetta.std
import pyrosetta.rosetta.utility
from typing import overload

class ElecAtom:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, res: pyrosetta.rosetta.core.conformation.Residue, atom_index: int) -> None: ...
    @overload
    def __init__(self, arg0: ElecAtom) -> None: ...
    def assign(self) -> ElecAtom: ...
    @overload
    def atom(self) -> pyrosetta.rosetta.core.conformation.Atom: ...
    @overload
    def atom(self, base: pyrosetta.rosetta.core.conformation.Atom) -> None: ...
    @overload
    def atom(self, constclasscore) -> void: ...
    @overload
    def charge(self) -> float: ...
    @overload
    def charge(self) -> double: ...
    @overload
    def charge(self, charge: float) -> None: ...
    @overload
    def charge(self, double) -> void: ...
    @overload
    def charges(self) -> pyrosetta.rosetta.utility.vector1_numeric_xyzVector_double_t: ...
    @overload
    def charges(self, charges: pyrosetta.rosetta.utility.vector1_numeric_xyzVector_double_t) -> None: ...
    @overload
    def charges(self, constclassutility) -> void: ...
    @overload
    def frac(self) -> float: ...
    @overload
    def frac(self) -> double: ...
    @overload
    def frac(self, frac: float) -> None: ...
    @overload
    def frac(self, double) -> void: ...
    @overload
    def is_hydrogen(self) -> bool: ...
    @overload
    def is_hydrogen(self) -> bool: ...
    @overload
    def is_hydrogen(self, setting: bool) -> None: ...
    @overload
    def is_hydrogen(self, bool) -> void: ...
    @overload
    def is_wat(self) -> bool: ...
    @overload
    def is_wat(self) -> bool: ...
    @overload
    def is_wat(self, setting: bool) -> None: ...
    @overload
    def is_wat(self, bool) -> void: ...
    @overload
    def isbb(self) -> bool: ...
    @overload
    def isbb(self) -> bool: ...
    @overload
    def isbb(self, isbb: bool) -> None: ...
    @overload
    def isbb(self, bool) -> void: ...
    @overload
    def load(self, arc: pyrosetta.rosetta.cereal.BinaryInputArchive) -> None: ...
    @overload
    def load(self, classcereal) -> void: ...
    @overload
    def print(self) -> None: ...
    @overload
    def print(self) -> void: ...
    @overload
    def print(self, os: pyrosetta.rosetta.std.ostream) -> None: ...
    @overload
    def print(self, std) -> void: ...
    @overload
    def save(self, arc: pyrosetta.rosetta.cereal.BinaryOutputArchive) -> None: ...
    @overload
    def save(self, classcereal) -> void: ...
    @overload
    def xyz(self) -> pyrosetta.rosetta.numeric.xyzVector_double_t: ...
    @overload
    def xyz(self, base: pyrosetta.rosetta.numeric.xyzVector_double_t) -> None: ...
    @overload
    def xyz(self, constclassnumeric) -> void: ...
    def __eq__(self, other: ElecAtom) -> bool: ...

class ElecTrieEvaluator:
    def __init__(self, wt_bb_bb: float, wt_bb_sc: float, wt_sc_bb: float, wt_sc_sc: float, elec: pyrosetta.rosetta.core.scoring.elec.FA_ElecEnergy) -> None: ...
    def elec_weight(self, at1isbb: bool, at2isbb: bool) -> float: ...
    def heavyatom_heavyatom_energy(self, at1: ElecAtom, at2: ElecAtom, d2: float) -> float: ...
    def heavyatom_hydrogenatom_energy(self, at1: ElecAtom, at2: ElecAtom) -> float: ...
    @overload
    def hydrogen_interaction_cutoff2(self) -> float: ...
    @overload
    def hydrogen_interaction_cutoff2(self) -> double: ...
    def hydrogenatom_heavyatom_energy(self, at1: ElecAtom, at2: ElecAtom) -> float: ...
    def hydrogenatom_hydrogenatom_energy(self, at1: ElecAtom, at2: ElecAtom) -> float: ...
