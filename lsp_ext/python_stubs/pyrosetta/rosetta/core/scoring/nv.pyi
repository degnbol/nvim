import pyrosetta.rosetta.core.chemical
import pyrosetta.rosetta.core.conformation
import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.core.scoring
import pyrosetta.rosetta.core.scoring.methods
import pyrosetta.rosetta.utility
from typing import overload

class NVlookup:
    @overload
    def __init__(self, filename: str) -> None: ...
    @overload
    def __init__(self, arg0: NVlookup) -> None: ...
    def assign(self) -> NVlookup: ...
    def get_potentials(self, aa_type: pyrosetta.rosetta.core.chemical.AA, score: float) -> float: ...

class NVscore(pyrosetta.rosetta.core.scoring.methods.ContextDependentOneBodyEnergy):
    def __init__(self) -> None: ...
    def clone(self) -> pyrosetta.rosetta.core.scoring.methods.EnergyMethod: ...
    @overload
    def indicate_required_context_graphs(self, context_graphs_required: pyrosetta.rosetta.utility.vector1_bool) -> None: ...
    @overload
    def indicate_required_context_graphs(self, classutility) -> void: ...
    def neighbor_weight(self, distance: float) -> float: ...
    def residue_energy(self, rsd: pyrosetta.rosetta.core.conformation.Residue, pose: pyrosetta.rosetta.core.pose.Pose, emap: pyrosetta.rosetta.core.scoring.EMapVector) -> None: ...
    @overload
    def setup_for_derivatives(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def setup_for_derivatives(self, classcore, constclasscore) -> void: ...
    def setup_for_minimizing(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    def setup_for_packing(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def setup_for_scoring(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def setup_for_scoring(self, classcore, constclasscore) -> void: ...

class NVscoreCreator(pyrosetta.rosetta.core.scoring.methods.EnergyMethodCreator):
    def __init__(self) -> None: ...
    def assign(self) -> NVscoreCreator: ...
    def create_energy_method(self) -> pyrosetta.rosetta.core.scoring.methods.EnergyMethod: ...
    def score_types_for_method(self) -> pyrosetta.rosetta.utility.vector1_core_scoring_ScoreType: ...
