import pyrosetta.rosetta.core.chemical.rna
import pyrosetta.rosetta.core.conformation
import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.numeric
from typing import overload

class MgKnowledgeBasedPotential:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: MgKnowledgeBasedPotential) -> None: ...
    def get_mg_potential_costheta_gaussian_parameter(self, rsd: pyrosetta.rosetta.core.conformation.Residue, j: int) -> pyrosetta.rosetta.core.chemical.rna.GaussianParameter: ...
    def get_mg_potential_costheta_indirect_gaussian_parameter(self, rsd: pyrosetta.rosetta.core.conformation.Residue, j: int) -> pyrosetta.rosetta.core.chemical.rna.GaussianParameter: ...
    @overload
    def get_mg_potential_gaussian_parameter(self, rsd: pyrosetta.rosetta.core.conformation.Residue, j: int, is_phosphate_oxygen: bool) -> pyrosetta.rosetta.core.chemical.rna.GaussianParameter: ...
    @overload
    def get_mg_potential_gaussian_parameter(self, rsd: pyrosetta.rosetta.core.conformation.Residue, j: int) -> pyrosetta.rosetta.core.chemical.rna.GaussianParameter: ...
    def get_mg_potential_indirect_gaussian_parameter(self, rsd: pyrosetta.rosetta.core.conformation.Residue, j: int) -> pyrosetta.rosetta.core.chemical.rna.GaussianParameter: ...
    @overload
    def setup_info_for_mg_calculation(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def setup_info_for_mg_calculation(self, classcore) -> void: ...
    @overload
    def v_angle_width(self) -> float: ...
    @overload
    def v_angle_width(self) -> double: ...

@overload
def get_closest_orbital_axis(mg_rsd: pyrosetta.rosetta.core.conformation.Residue, j_xyz: pyrosetta.rosetta.numeric.xyzVector_double_t) -> int: ...
@overload
def get_closest_orbital_axis(constclasscore, constclassnumeric) -> unsignedlong: ...
@overload
def get_cos_angle_to_closest_orbital_axis(rsd1: pyrosetta.rosetta.core.conformation.Residue, j_xyz: pyrosetta.rosetta.numeric.xyzVector_double_t) -> float: ...
@overload
def get_cos_angle_to_closest_orbital_axis(constclasscore, constclassnumeric) -> double: ...
@overload
def get_cos_theta(rsd1: pyrosetta.rosetta.core.conformation.Residue, i: int, j_xyz: pyrosetta.rosetta.numeric.xyzVector_double_t) -> float: ...
@overload
def get_cos_theta(rsd1: pyrosetta.rosetta.core.conformation.Residue, i: int, j_xyz: pyrosetta.rosetta.numeric.xyzVector_double_t, i_base: int) -> float: ...
@overload
def get_cos_theta(rsd1: pyrosetta.rosetta.core.conformation.Residue, i: int, j_xyz: pyrosetta.rosetta.numeric.xyzVector_double_t, i_base: int, xyz_base: pyrosetta.rosetta.numeric.xyzVector_double_t) -> float: ...
def get_gaussian_deriv(mg_potential_gaussian_parameter: pyrosetta.rosetta.core.chemical.rna.GaussianParameter, d: float) -> float: ...
def get_gaussian_potential_score(mg_potential_gaussian_parameter: pyrosetta.rosetta.core.chemical.rna.GaussianParameter, pos1: pyrosetta.rosetta.numeric.xyzVector_double_t, pos2: pyrosetta.rosetta.numeric.xyzVector_double_t) -> float: ...
def get_gaussian_score(mg_potential_gaussian_parameter: pyrosetta.rosetta.core.chemical.rna.GaussianParameter, d: float) -> float: ...
