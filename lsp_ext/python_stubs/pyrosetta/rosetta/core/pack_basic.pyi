import pyrosetta.rosetta.cereal
import pyrosetta.rosetta.core.conformation
import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.std
from typing import overload

class RotamerSetsBase:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: RotamerSetsBase) -> None: ...
    def assign(self) -> RotamerSetsBase: ...
    @overload
    def initialize_pose_for_rotsets_creation(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def initialize_pose_for_rotsets_creation(self, classcore) -> void: ...
    @overload
    def load(self, arc: pyrosetta.rosetta.cereal.BinaryInputArchive) -> None: ...
    @overload
    def load(self, classcereal) -> void: ...
    @overload
    def moltenres_2_resid(self) -> int: ...
    @overload
    def moltenres_2_resid(self, unsignedlong) -> unsignedlong: ...
    @overload
    def moltenres_for_rotamer(self) -> int: ...
    @overload
    def moltenres_for_rotamer(self, unsignedlong) -> unsignedlong: ...
    def moltenres_rotid_2_rotid(self, moltenres: int, moltenresrotid: int) -> int: ...
    @overload
    def nmoltenres(self) -> int: ...
    @overload
    def nmoltenres(self) -> unsignedlong: ...
    @overload
    def nrotamer_offset_for_moltenres(self) -> int: ...
    @overload
    def nrotamer_offset_for_moltenres(self, unsignedlong) -> unsignedlong: ...
    @overload
    def nrotamers(self) -> int: ...
    @overload
    def nrotamers(self) -> unsignedlong: ...
    @overload
    def nrotamers_for_moltenres(self) -> int: ...
    @overload
    def nrotamers_for_moltenres(self, unsignedlong) -> unsignedlong: ...
    @overload
    def res_for_rotamer(self) -> int: ...
    @overload
    def res_for_rotamer(self, unsignedlong) -> unsignedlong: ...
    @overload
    def resid_2_moltenres(self) -> int: ...
    @overload
    def resid_2_moltenres(self, unsignedlong) -> unsignedlong: ...
    def rotamer(self) -> pyrosetta.rosetta.core.conformation.Residue: ...
    def rotamer_for_moltenres(self, moltenres_id: int, rotamerid: int) -> pyrosetta.rosetta.core.conformation.Residue: ...
    @overload
    def rotid_on_moltenresidue(self, rotid: int) -> int: ...
    @overload
    def rotid_on_moltenresidue(self, unsignedlong) -> unsignedlong: ...
    @overload
    def save(self, arc: pyrosetta.rosetta.cereal.BinaryOutputArchive) -> None: ...
    @overload
    def save(self, classcereal) -> void: ...
    @overload
    def show(self, out: pyrosetta.rosetta.std.ostream) -> None: ...
    @overload
    def show(self, std) -> void: ...
    @overload
    def total_residue(self) -> int: ...
    @overload
    def total_residue(self) -> unsignedlong: ...
