def write_binary(constclassstd, structcore) -> void: ...
@overload
def write_binary(x: str, buf: BUFFER) -> None: ...
@overload
def write_binary(conststd, structcore) -> void: ...
@overload
def write_binary(x: pyrosetta.rosetta.numeric.xyzVector_double_t, buf: BUFFER) -> None: ...
@overload
def write_binary(constclassnumeric, structcore) -> void: ...
