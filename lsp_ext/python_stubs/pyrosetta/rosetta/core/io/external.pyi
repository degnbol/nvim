import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.utility
from typing import overload

class PsiPredInterface:
    @overload
    def __init__(self, cmd: str) -> None: ...
    @overload
    def __init__(self, cmd: str, scratch_dir: str) -> None: ...
    @overload
    def __init__(self, arg0: PsiPredInterface) -> None: ...
    def run_psipred(self, pose: pyrosetta.rosetta.core.pose.Pose, blueprint_ss: str) -> PsiPredResult: ...
    def run_psipred_prob(self, pose: pyrosetta.rosetta.core.pose.Pose) -> pyrosetta.rosetta.utility.vector1_utility_vector1_utility_vector1_double_t: ...

class PsiPredResult:
    nres: int
    pred_ss: str
    psipred2_confidence: pyrosetta.rosetta.utility.vector1_unsigned_long
    psipred_prob: pyrosetta.rosetta.utility.vector1_double
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: PsiPredResult) -> None: ...
    def assign(self) -> PsiPredResult: ...

def generate_prob(psipred_result: PsiPredResult, desired_ss: str) -> pyrosetta.rosetta.utility.vector1_double: ...
def nonmatching_residues(blueprint_ss: str, pred_ss: str) -> pyrosetta.rosetta.utility.vector1_unsigned_long: ...
