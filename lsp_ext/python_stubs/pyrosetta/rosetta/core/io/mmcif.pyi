import pyrosetta.rosetta.core.io
import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.std
from typing import overload

@overload
def dump_cif(pose: pyrosetta.rosetta.core.pose.Pose, file_name: str) -> bool: ...
@overload
def dump_cif(pose: pyrosetta.rosetta.core.pose.Pose, file_name: str, options: pyrosetta.rosetta.core.io.StructFileRepOptions) -> bool: ...
@overload
def dump_cif(constclasscore, conststd, classstd) -> bool: ...
@overload
def dump_cif(pose: pyrosetta.rosetta.core.pose.Pose, out: pyrosetta.rosetta.std.ostream) -> pyrosetta.rosetta.core.io.StructFileRep: ...
@overload
def dump_cif(pose: pyrosetta.rosetta.core.pose.Pose, out: pyrosetta.rosetta.std.ostream, options: pyrosetta.rosetta.core.io.StructFileRepOptions) -> pyrosetta.rosetta.core.io.StructFileRep: ...
@overload
def dump_cif(pose: pyrosetta.rosetta.core.pose.Pose) -> str: ...
@overload
def dump_cif(pose: pyrosetta.rosetta.core.pose.Pose, jd2_job_data: str, out: pyrosetta.rosetta.std.ostream) -> pyrosetta.rosetta.core.io.StructFileRep: ...
@overload
def dump_cif(sfr: pyrosetta.rosetta.core.io.StructFileRep, options: pyrosetta.rosetta.core.io.StructFileRepOptions) -> str: ...
@overload
def dump_cif(file_name: str, sfr: pyrosetta.rosetta.core.io.StructFileRep, options: pyrosetta.rosetta.core.io.StructFileRepOptions) -> bool: ...
@overload
def dump_cif(conststd, classstd, constclasscore) -> bool: ...
@overload
def dump_cif(out: pyrosetta.rosetta.std.ostream, sfr: pyrosetta.rosetta.core.io.StructFileRep, options: pyrosetta.rosetta.core.io.StructFileRepOptions) -> None: ...
@overload
def dump_cif(std, classstd, constclasscore) -> void: ...
