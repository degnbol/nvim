        __members__: ClassVar[dict] = ...  # read-only
        __entries: ClassVar[dict] = ...
        conformation: ClassVar[UIObserver.ObserverType] = ...
        energy: ClassVar[UIObserver.ObserverType] = ...
        general: ClassVar[UIObserver.ObserverType] = ...
        none: ClassVar[UIObserver.ObserverType] = ...
        def __init__(self, value: int) -> None: ...
        def __eq__(self, other: object) -> bool: ...
        def __hash__(self) -> int: ...
        def __index__(self) -> int: ...
        def __int__(self) -> int: ...
        def __ne__(self, other: object) -> bool: ...
        @property
        def name(self) -> str: ...
        @property
        def value(self) -> int: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: UIObserver) -> None: ...
    @overload
    def __init__(self, arg0: UIObserver) -> None: ...
    @overload
    def add_type(self, setting: UIObserver.ObserverType) -> None: ...
    @overload
    def add_type(self, enumprotocols) -> void: ...
    def assign(self) -> UIObserver: ...
    @overload
    def attach(self, p: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def attach(self, classcore) -> void: ...
    def clone(self) -> pyrosetta.rosetta.core.pose.datacache.CacheableObserver: ...
    @overload
    def conformationEvent(self, ev: pyrosetta.rosetta.core.pose.signals.ConformationEvent) -> None: ...
    @overload
    def conformationEvent(self, conststructcore) -> void: ...
    def create(self) -> pyrosetta.rosetta.core.pose.datacache.CacheableObserver: ...
    @overload
    def detach(self, p: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def detach(self, classcore) -> void: ...
    @overload
    def energyEvent(self, ev: pyrosetta.rosetta.core.pose.signals.EnergyEvent) -> None: ...
    @overload
    def energyEvent(self, conststructcore) -> void: ...
    @overload
    def generalEvent(self, ev: pyrosetta.rosetta.core.pose.signals.GeneralEvent) -> None: ...
    @overload
    def generalEvent(self, conststructcore) -> void: ...
    def get_type(self) -> UIObserver.ObserverType: ...
    @overload
    def is_attached(self) -> bool: ...
    @overload
    def is_attached(self) -> bool: ...
    @overload
    def set_type(self, setting: UIObserver.ObserverType) -> None: ...
    @overload
    def set_type(self, enumprotocols) -> void: ...
    def ui_mover(self) -> UIMover: ...

