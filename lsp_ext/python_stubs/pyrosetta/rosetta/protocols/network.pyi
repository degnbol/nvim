class UIMover(pyrosetta.rosetta.protocols.moves.Mover):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: UIMover) -> None: ...
    @overload
    def __init__(self, arg0: UIMover) -> None: ...
    @overload
    def apply(self) -> None: ...
    @overload
    def apply(self, classcore) -> void: ...
    @overload
    def apply(self) -> None: ...
    @overload
    def apply(self, constclasscore) -> void: ...
    def assign(self, other: UIMover) -> UIMover: ...
    def get_name(self) -> str: ...

class UIObserver(pyrosetta.rosetta.core.pose.datacache.CacheableObserver):
