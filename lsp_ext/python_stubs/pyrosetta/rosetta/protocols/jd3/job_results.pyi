import pyrosetta.rosetta.cereal
import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.protocols.jd3
from typing import overload

class PoseJobResult(pyrosetta.rosetta.protocols.jd3.JobResult):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def __init__(self, arg0: PoseJobResult) -> None: ...
    @overload
    def __init__(self, arg0: PoseJobResult) -> None: ...
    def assign(self) -> PoseJobResult: ...
    @overload
    def load(self, arc: pyrosetta.rosetta.cereal.BinaryInputArchive) -> None: ...
    @overload
    def load(self, classcereal) -> void: ...
    @overload
    def pose(self) -> pyrosetta.rosetta.core.pose.Pose: ...
    @overload
    def pose(self, setting: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def pose(self, classstd) -> void: ...
    @overload
    def save(self, arc: pyrosetta.rosetta.cereal.BinaryOutputArchive) -> None: ...
    @overload
    def save(self, classcereal) -> void: ...
    def status(self) -> pyrosetta.rosetta.protocols.jd3.JobStatus: ...
