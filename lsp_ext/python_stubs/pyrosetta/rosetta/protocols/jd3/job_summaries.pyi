import pyrosetta.rosetta.cereal
import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.core.simple_metrics
import pyrosetta.rosetta.protocols.jd3
from typing import overload

class EnergyJobSummary(pyrosetta.rosetta.protocols.jd3.JobSummary):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, energy: float) -> None: ...
    @overload
    def __init__(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def __init__(self, arg0: EnergyJobSummary) -> None: ...
    def assign(self) -> EnergyJobSummary: ...
    @overload
    def energy(self, setting: float) -> None: ...
    @overload
    def energy(self, double) -> void: ...
    @overload
    def energy(self) -> float: ...
    @overload
    def energy(self) -> double: ...
    @overload
    def extract_energy(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def extract_energy(self, constclasscore) -> void: ...
    @overload
    def load(self, arc: pyrosetta.rosetta.cereal.BinaryInputArchive) -> None: ...
    @overload
    def load(self, classcereal) -> void: ...
    @overload
    def save(self, arc: pyrosetta.rosetta.cereal.BinaryOutputArchive) -> None: ...
    @overload
    def save(self, classcereal) -> void: ...

class StandardPoseJobSummary(pyrosetta.rosetta.protocols.jd3.JobSummary):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def __init__(self, arg0: StandardPoseJobSummary) -> None: ...
    def assign(self) -> StandardPoseJobSummary: ...
    @overload
    def energy(self) -> float: ...
    @overload
    def energy(self) -> double: ...
    @overload
    def extract_summary(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def extract_summary(self, constclasscore) -> void: ...
    @overload
    def load(self, arc: pyrosetta.rosetta.cereal.BinaryInputArchive) -> None: ...
    @overload
    def load(self, classcereal) -> void: ...
    def metric_data(self) -> pyrosetta.rosetta.core.simple_metrics.SimpleMetricData: ...
    @overload
    def save(self, arc: pyrosetta.rosetta.cereal.BinaryOutputArchive) -> None: ...
    @overload
    def save(self, classcereal) -> void: ...
    @overload
    def set_energy(self, energy: float) -> None: ...
    @overload
    def set_energy(self, double) -> void: ...
