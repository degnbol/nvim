import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.protocols.docking
from typing import overload

class SaneDockingProtocol(pyrosetta.rosetta.protocols.docking.DockingProtocol):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: SaneDockingProtocol) -> None: ...
    @overload
    def __init__(self, arg0: SaneDockingProtocol) -> None: ...
    @overload
    def apply(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def apply(self, classcore) -> void: ...
    def assign(self) -> SaneDockingProtocol: ...
    def get_name(self) -> str: ...
