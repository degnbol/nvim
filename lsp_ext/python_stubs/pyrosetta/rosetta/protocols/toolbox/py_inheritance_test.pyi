from typing import overload

class Base:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: Base) -> None: ...
    @overload
    def __init__(self, arg0: Base) -> None: ...
    def assign(self) -> Base: ...
    def who_am_i(self) -> str: ...

class O_1A(Base):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: O_1A) -> None: ...
    @overload
    def __init__(self, arg0: O_1A) -> None: ...
    def assign(self) -> O_1A: ...
    def who_am_i(self) -> str: ...

class O_1B(Base):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: O_1B) -> None: ...
    @overload
    def __init__(self, arg0: O_1B) -> None: ...
    def assign(self) -> O_1B: ...
    def who_am_i(self) -> str: ...

class O_2A(O_1A):
    def __init__(self) -> None: ...
    def assign(self) -> O_2A: ...
    def who_am_i(self) -> str: ...

class O_2A2B(O_2A, O_2B):
    def __init__(self) -> None: ...
    def assign(self) -> O_2A2B: ...
    def who_am_i(self) -> str: ...

class O_2B(O_1B):
    def __init__(self) -> None: ...
    def assign(self) -> O_2B: ...
    def who_am_i(self) -> str: ...

def take_Base_SP(s: Base) -> str: ...
def take_Base_pointer(p: Base) -> str: ...
def take_Base_reference(r: Base) -> str: ...
def take_O_1A_SP(s: O_1A) -> str: ...
def take_O_1A_pointer(p: O_1A) -> str: ...
def take_O_1A_reference(r: O_1A) -> str: ...
def take_O_2A_SP(s: O_2A) -> str: ...
def take_O_2A_pointer(p: O_2A) -> str: ...
def take_O_2A_reference(r: O_2A) -> str: ...
