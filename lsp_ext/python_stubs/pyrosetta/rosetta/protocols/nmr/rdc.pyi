import pyrosetta.rosetta.core.id
import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.core.scoring
import pyrosetta.rosetta.core.scoring.methods
import pyrosetta.rosetta.core.scoring.nmr.rdc
import pyrosetta.rosetta.numeric
import pyrosetta.rosetta.std
import pyrosetta.rosetta.utility
from typing import overload

class RDCEnergy(pyrosetta.rosetta.core.scoring.methods.WholeStructureEnergy):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: RDCEnergy) -> None: ...
    @overload
    def __init__(self, arg0: RDCEnergy) -> None: ...
    def assign(self) -> RDCEnergy: ...
    @overload
    def calcualate_total_score_and_tensors(self, pose: pyrosetta.rosetta.core.pose.Pose) -> float: ...
    @overload
    def calcualate_total_score_and_tensors(self, classcore) -> double: ...
    def clone(self) -> pyrosetta.rosetta.core.scoring.methods.EnergyMethod: ...
    def eval_atom_derivative(self, id: pyrosetta.rosetta.core.id.AtomID, pose: pyrosetta.rosetta.core.pose.Pose, weights: pyrosetta.rosetta.core.scoring.EMapVector, F1: pyrosetta.rosetta.numeric.xyzVector_double_t, F2: pyrosetta.rosetta.numeric.xyzVector_double_t) -> None: ...
    def finalize_total_energy(self, pose: pyrosetta.rosetta.core.pose.Pose, totals: pyrosetta.rosetta.core.scoring.EMapVector) -> None: ...
    def get_rdc_data_from_pose(self, pose: pyrosetta.rosetta.core.pose.Pose) -> pyrosetta.rosetta.core.scoring.nmr.rdc.RDCData: ...
    @overload
    def indicate_required_context_graphs(self) -> None: ...
    @overload
    def indicate_required_context_graphs(self, classutility) -> void: ...
    def setup_for_minimizing(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def show_additional_info(self, TR: pyrosetta.rosetta.std.ostream, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def show_additional_info(self, TR: pyrosetta.rosetta.std.ostream, pose: pyrosetta.rosetta.core.pose.Pose, verbose: bool) -> None: ...
    @overload
    def show_additional_info(self, std, classcore, bool) -> void: ...
    @overload
    def version(self) -> int: ...
    @overload
    def version(self) -> unsignedlong: ...

class RDCEnergyCreator(pyrosetta.rosetta.core.scoring.methods.EnergyMethodCreator):
    def __init__(self) -> None: ...
    def assign(self) -> RDCEnergyCreator: ...
    def create_energy_method(self) -> pyrosetta.rosetta.core.scoring.methods.EnergyMethod: ...
    def score_types_for_method(self) -> pyrosetta.rosetta.utility.vector1_core_scoring_ScoreType: ...
