import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.protocols.kinematic_closure
import pyrosetta.rosetta.protocols.kinematic_closure.perturbers
import pyrosetta.rosetta.protocols.loophash
import pyrosetta.rosetta.utility
from typing import Any, overload

class LoopHashPerturber(pyrosetta.rosetta.protocols.kinematic_closure.perturbers.Perturber):
    def __init__(self, lh_library) -> None: ...
    def extract_fragment(self, frag_index: int, loop_size: int) -> tuple[pyrosetta.rosetta.protocols.loophash.BackboneSegment, str]: ...
    def get_backbone_segments(self, pose: pyrosetta.rosetta.core.pose.Pose, loophash_fragment_start: int, loophash_fragment_end: int) -> None: ...
    def get_name(self) -> str: ...
    def get_random_backbone_segments(self, pose: pyrosetta.rosetta.core.pose.Pose, loophash_fragment_start: int, loophash_fragment_end: int) -> None: ...
    @overload
    def perturb_sequence(self, value: bool) -> None: ...
    @overload
    def perturb_sequence(self, bool) -> void: ...
    @overload
    def perturb_subset(self, pose: pyrosetta.rosetta.core.pose.Pose, residues: pyrosetta.rosetta.utility.vector1_unsigned_long, problem: pyrosetta.rosetta.protocols.kinematic_closure.ClosureProblem) -> None: ...
    @overload
    def perturb_subset(self) -> Any: ...
    @overload
    def perturb_subset(self, constclasscore, constclassutility, classstd) -> void: ...
    @overload
    def perturb_subset_with_balance(self, pose: pyrosetta.rosetta.core.pose.Pose, residues: pyrosetta.rosetta.utility.vector1_unsigned_long, problem: pyrosetta.rosetta.protocols.kinematic_closure.ClosureProblem) -> None: ...
    @overload
    def perturb_subset_with_balance(self) -> Any: ...
    @overload
    def perturb_subset_with_balance(self, constclasscore, constclassutility, classstd) -> void: ...
    @overload
    def random_mode(self, value: bool) -> None: ...
    @overload
    def random_mode(self, bool) -> void: ...
    @overload
    def seqposes_no_mutate_str(self, value: str) -> None: ...
    @overload
    def seqposes_no_mutate_str(self, std) -> void: ...
    @overload
    def use_radial_lookup(self, value: bool) -> None: ...
    @overload
    def use_radial_lookup(self, bool) -> void: ...
