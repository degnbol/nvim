class OopMover(pyrosetta.rosetta.protocols.moves.Mover):
    @overload
    def __init__(self, oop_seq_position: int) -> None: ...
    @overload
    def __init__(self, oop_seq_position: int, phi_angle: float, psi_angle: float) -> None: ...
    @overload
    def __init__(self, arg0: OopMover) -> None: ...
    @overload
    def __init__(self, arg0: OopMover) -> None: ...
    @overload
    def apply(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def apply(self, classcore) -> void: ...
    def get_name(self) -> str: ...
    @overload
    def set_phi(self, angle: float) -> None: ...
    @overload
    def set_phi(self, double) -> void: ...
    @overload
    def set_psi(self, angle: float) -> None: ...
    @overload
    def set_psi(self, double) -> void: ...
    @overload
    def update_hydrogens(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def update_hydrogens(self, classcore) -> void: ...

