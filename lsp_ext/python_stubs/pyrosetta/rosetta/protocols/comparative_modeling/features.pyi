class ResidueFeature:
    def __init__(self, *args, **kwargs) -> None: ...
    def assign(self) -> ResidueFeature: ...
    def clone(self) -> ResidueFeature: ...
    @overload
    def remap(self, mapping: pyrosetta.rosetta.core.id.SequenceMapping) -> None: ...
    @overload
    def remap(self, constclasscore) -> void: ...
    @overload
    def resnum(self) -> int: ...
    @overload
    def resnum(self) -> unsignedlong: ...
    @overload
    def resnum(self, resnum: int) -> None: ...
    @overload
    def resnum(self, constunsignedlong) -> void: ...
    def type(self) -> str: ...

class ResidueFeatureFactory:
    feature_types_: Incomplete
    @overload
    def __init__(self) -> None: ...
