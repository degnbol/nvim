    def add_type(self, feature_: ResidueFeature) -> None: ...
    @overload
    def add_type(self, classstd) -> void: ...
    def assign(self) -> ResidueFeatureFactory: ...
    def get_residue_feature(self, type: str) -> ResidueFeature: ...

