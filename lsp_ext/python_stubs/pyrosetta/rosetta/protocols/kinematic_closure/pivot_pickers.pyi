import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.protocols.loops
import pyrosetta.rosetta.utility
from typing import overload

class EndToEndPivots(PivotPicker):
    def __init__(self) -> None: ...
    def get_name(self) -> str: ...
    def pick(self, pose: pyrosetta.rosetta.core.pose.Pose, loop: pyrosetta.rosetta.protocols.loops.Loop) -> pyrosetta.rosetta.protocols.loops.Loop: ...

class FixedOffsetPivots(PivotPicker):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, offset: int) -> None: ...
    def get_name(self) -> str: ...
    def pick(self, pose: pyrosetta.rosetta.core.pose.Pose, loop: pyrosetta.rosetta.protocols.loops.Loop) -> pyrosetta.rosetta.protocols.loops.Loop: ...

class FixedOffsetsPivots(PivotPicker):
    def __init__(self, offsets: pyrosetta.rosetta.utility.vector1_unsigned_long) -> None: ...
    def get_name(self) -> str: ...
    def pick(self, pose: pyrosetta.rosetta.core.pose.Pose, loop: pyrosetta.rosetta.protocols.loops.Loop) -> pyrosetta.rosetta.protocols.loops.Loop: ...

class FixedPivots(PivotPicker):
    def __init__(self, start: int, stop: int, cut: int) -> None: ...
    def get_name(self) -> str: ...
    def pick(self, pose: pyrosetta.rosetta.core.pose.Pose, loop: pyrosetta.rosetta.protocols.loops.Loop) -> pyrosetta.rosetta.protocols.loops.Loop: ...

class LoopPivots(PivotPicker):
    def __init__(self) -> None: ...
    def get_name(self) -> str: ...
    def pick(self, pose: pyrosetta.rosetta.core.pose.Pose, loop: pyrosetta.rosetta.protocols.loops.Loop) -> pyrosetta.rosetta.protocols.loops.Loop: ...

class PivotPicker:
    def __init__(self) -> None: ...
    def get_name(self) -> str: ...
    def pick(self, pose: pyrosetta.rosetta.core.pose.Pose, loop: pyrosetta.rosetta.protocols.loops.Loop) -> pyrosetta.rosetta.protocols.loops.Loop: ...

class StandardPivots(PivotPicker):
    def __init__(self) -> None: ...
    def get_name(self) -> str: ...
    def pick(self, pose: pyrosetta.rosetta.core.pose.Pose, loop: pyrosetta.rosetta.protocols.loops.Loop) -> pyrosetta.rosetta.protocols.loops.Loop: ...
