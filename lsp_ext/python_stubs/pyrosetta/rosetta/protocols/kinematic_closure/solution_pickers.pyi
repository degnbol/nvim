import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.utility
from typing import overload

class FilteredSolutions(SolutionPicker):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: bool) -> None: ...
    @overload
    def __init__(self, arg0: bool, arg1: bool) -> None: ...
    @overload
    def __init__(self, check_rama: bool, check_overlap: bool, be_lenient: bool) -> None: ...
    @overload
    def be_lenient(self) -> None: ...
    @overload
    def be_lenient(self) -> void: ...
    @overload
    def check_overlap(self) -> None: ...
    @overload
    def check_overlap(self) -> void: ...
    @overload
    def check_rama(self) -> None: ...
    @overload
    def check_rama(self) -> void: ...
    @overload
    def dont_be_lenient(self) -> None: ...
    @overload
    def dont_be_lenient(self) -> void: ...
    @overload
    def dont_check_overlap(self) -> None: ...
    @overload
    def dont_check_overlap(self) -> void: ...
    @overload
    def dont_check_rama(self) -> None: ...
    @overload
    def dont_check_rama(self) -> void: ...
    @overload
    def pick_and_apply(self, pose: pyrosetta.rosetta.core.pose.Pose, solutions: pyrosetta.rosetta.utility.vector1_std_shared_ptr_const_protocols_kinematic_closure_ClosureSolution_t) -> bool: ...
    @overload
    def pick_and_apply(self, classcore, constclassutility) -> bool: ...

class RandomSolutions(SolutionPicker):
    def __init__(self) -> None: ...
    @overload
    def pick_and_apply(self, pose: pyrosetta.rosetta.core.pose.Pose, solutions: pyrosetta.rosetta.utility.vector1_std_shared_ptr_const_protocols_kinematic_closure_ClosureSolution_t) -> bool: ...
    @overload
    def pick_and_apply(self, classcore, constclassutility) -> bool: ...

class SolutionPicker:
    def __init__(self) -> None: ...
    @overload
    def pick_and_apply(self, pose: pyrosetta.rosetta.core.pose.Pose, solutions: pyrosetta.rosetta.utility.vector1_std_shared_ptr_const_protocols_kinematic_closure_ClosureSolution_t) -> bool: ...
    @overload
    def pick_and_apply(self, classcore, constclassutility) -> bool: ...
