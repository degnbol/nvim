from typing import overload

class Contact:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, p1: ContactPartner) -> None: ...
    @overload
    def __init__(self, p1: ContactPartner, p2: ContactPartner) -> None: ...
    @overload
    def add_distance(self) -> None: ...
    @overload
    def add_distance(self) -> void: ...
    @overload
    def add_distance(self, distance: float) -> None: ...
    @overload
    def add_distance(self, double) -> void: ...
    @overload
    def long_string_rep(self) -> str: ...
    @overload
    def long_string_rep(self, n_poses: int) -> str: ...
    def partner1(self) -> ContactPartner: ...
    def partner2(self) -> ContactPartner: ...
    @overload
    def reset_count(self) -> None: ...
    @overload
    def reset_count(self) -> void: ...
    @overload
    def string_rep(self) -> str: ...
    @overload
    def string_rep(self, n_poses: int) -> str: ...

