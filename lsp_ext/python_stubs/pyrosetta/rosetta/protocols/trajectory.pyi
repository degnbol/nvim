import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.utility
from typing import overload

class DbTrajectoryReader:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, job_id: int) -> None: ...
    def get_iterations(self) -> pyrosetta.rosetta.utility.vector1_unsigned_long: ...
    @overload
    def get_num_iterations(self) -> int: ...
    @overload
    def get_num_iterations(self) -> unsignedlong: ...
    def get_pose(self, iteration: int) -> pyrosetta.rosetta.core.pose.Pose: ...
    def get_poses(self) -> pyrosetta.rosetta.utility.vector1_core_pose_Pose: ...
    @overload
    def set_job_id(self, job_id: int) -> None: ...
    @overload
    def set_job_id(self, unsignedlong) -> void: ...

class DbTrajectoryWriter:
    class Frame:
        iteration: int
        pose: pyrosetta.rosetta.core.pose.Pose
        @overload
        def __init__(self) -> None: ...
        @overload
        def __init__(self, arg0: DbTrajectoryWriter.Frame) -> None: ...
        def assign(self) -> DbTrajectoryWriter.Frame: ...
    @overload
    def __init__(self, job_id: int, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def __init__(self, job_id: int, pose: pyrosetta.rosetta.core.pose.Pose, frequency: int) -> None: ...
    @overload
    def __init__(self, job_id: int, pose: pyrosetta.rosetta.core.pose.Pose, frequency: int, cache_limit: int) -> None: ...
    @overload
    def finalize(self) -> None: ...
    @overload
    def finalize(self) -> void: ...
    @overload
    def set_cache_limit(self, setting: int) -> None: ...
    @overload
    def set_cache_limit(self, unsignedlong) -> void: ...
    @overload
    def set_frequency(self, setting: int) -> None: ...
    @overload
    def set_frequency(self, unsignedlong) -> void: ...
    @overload
    def update(self, pose: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def update(self, constclasscore) -> void: ...
