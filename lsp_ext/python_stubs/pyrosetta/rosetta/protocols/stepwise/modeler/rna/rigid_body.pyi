import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.utility
from typing import overload

class BaseBin:
    centroid_x: int
    centroid_y: int
    centroid_z: int
    euler_alpha: int
    euler_gamma: int
    euler_z: int
    def __init__(self) -> None: ...

class compare_base_bin:
    def __init__(self) -> None: ...
    def __call__(self, first: BaseBin, second: BaseBin) -> bool: ...

class compare_int_pair:
    def __init__(self) -> None: ...
    def __call__(self, pair_one: tuple[int, int], pair_two: tuple[int, int]) -> bool: ...

@overload
def DOF_bin_size(DOF: str) -> float: ...
@overload
def DOF_bin_size(conststd) -> double: ...
@overload
def DOF_bin_value(base_bin: BaseBin, DOF: str) -> int: ...
@overload
def DOF_bin_value(conststructprotocols, conststd) -> int: ...
@overload
def get_max_centroid_to_atom_distance(rsd_at_origin_list: pyrosetta.rosetta.utility.vector1_std_shared_ptr_core_conformation_Residue_t, atom_name: str) -> float: ...
@overload
def get_max_centroid_to_atom_distance(constclassutility, conststd) -> double: ...
def initialize_xyz_parameters(max_distance: float, max_distance_squared: float, centroid_bin_min: int, centroid_bin_max: int, moving_rsd_at_origin_list: pyrosetta.rosetta.utility.vector1_std_shared_ptr_core_conformation_Residue_t, gap_size_to_anchor: int) -> None: ...
def setup_pose_with_moving_residue_alternative_list(pose: pyrosetta.rosetta.core.pose.Pose, moving_res: int, extra_chi: bool, use_phenix_geo: bool) -> pyrosetta.rosetta.utility.vector1_std_shared_ptr_core_pose_Pose_t: ...
