import pyrosetta.rosetta.protocols.moves
from typing import overload

class BulgeApplyMover(pyrosetta.rosetta.protocols.moves.Mover):
    def __init__(self, moving_res: int) -> None: ...
    @overload
    def apply(self) -> None: ...
    @overload
    def apply(self, classcore) -> void: ...
    def get_name(self) -> str: ...

class BulgeUnApplyMover(pyrosetta.rosetta.protocols.moves.Mover):
    def __init__(self, moving_res: int) -> None: ...
    @overload
    def apply(self) -> None: ...
    @overload
    def apply(self, classcore) -> void: ...
    def get_name(self) -> str: ...
