import pyrosetta.rosetta.core.pose
import pyrosetta.rosetta.utility
from typing import overload

class ProteinAtrRepChecker:
    @overload
    def __init__(self, pose: pyrosetta.rosetta.core.pose.Pose, moving_res_list: pyrosetta.rosetta.utility.vector1_unsigned_long) -> None: ...
    @overload
    def __init__(self, arg0: ProteinAtrRepChecker) -> None: ...
    @overload
    def base_atr_score(self) -> float: ...
    @overload
    def base_atr_score(self) -> double: ...
    @overload
    def base_rep_score(self) -> float: ...
    @overload
    def base_rep_score(self) -> double: ...
    @overload
    def check_screen(self, current_pose_screen: pyrosetta.rosetta.core.pose.Pose) -> bool: ...
    @overload
    def check_screen(self, classcore) -> bool: ...
    @overload
    def delta_atr_score(self) -> float: ...
    @overload
    def delta_atr_score(self) -> double: ...
    @overload
    def delta_rep_score(self) -> float: ...
    @overload
    def delta_rep_score(self) -> double: ...
