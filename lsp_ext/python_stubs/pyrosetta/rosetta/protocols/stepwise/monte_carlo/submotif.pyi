    @overload
    def __init__(self, rsd_set: pyrosetta.rosetta.core.chemical.ResidueTypeSet, include_submotifs_from_jump_library: bool) -> None: ...
    @overload
    def __init__(self, rsd_set: pyrosetta.rosetta.core.chemical.ResidueTypeSet, include_submotifs_from_jump_library: bool, use_first_jump_for_submotif: bool) -> None: ...
