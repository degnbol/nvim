from typing import overload

class AbinitioMoverWeight:
    @overload
    def __init__(self, arg0: AbinitioMoverWeight) -> None: ...
    @overload
    def __init__(self) -> None: ...
    def assign(self) -> AbinitioMoverWeight: ...
    @overload
    def weight(self, stageID: int, progress: float) -> float: ...
    @overload
    def weight(self, unsignedlong, double) -> double: ...

class ConstAbinitioMoverWeight(AbinitioMoverWeight):
    @overload
    def __init__(self, weight: float) -> None: ...
    @overload
    def __init__(self, arg0: ConstAbinitioMoverWeight) -> None: ...
    @overload
    def __init__(self, arg0: ConstAbinitioMoverWeight) -> None: ...
    def assign(self) -> ConstAbinitioMoverWeight: ...
    @overload
    def weight(self) -> float: ...
    @overload
    def weight(self, unsignedlong, double) -> double: ...

