import pyrosetta.rosetta.utility
from typing import ClassVar, overload

EBC_bb_cartesian: EBC_ClusterType
EBC_bb_dihedral: EBC_ClusterType
EBC_end_of_list: EBC_ClusterType

class EBC_ClusterType:
    __members__: ClassVar[dict] = ...  # read-only
    EBC_bb_cartesian: ClassVar[EBC_ClusterType] = ...
    EBC_bb_dihedral: ClassVar[EBC_ClusterType] = ...
    EBC_end_of_list: ClassVar[EBC_ClusterType] = ...
    __entries: ClassVar[dict] = ...
    def __init__(self, value: int) -> None: ...
    def __and__(self, other: object) -> object: ...
    def __eq__(self, other: object) -> bool: ...
    def __ge__(self, other: object) -> bool: ...
    def __gt__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def __index__(self) -> int: ...
    def __int__(self) -> int: ...
    def __invert__(self) -> object: ...
    def __le__(self, other: object) -> bool: ...
    def __lt__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __or__(self, other: object) -> object: ...
    def __rand__(self, other: object) -> object: ...
    def __ror__(self, other: object) -> object: ...
    def __rxor__(self, other: object) -> object: ...
    def __xor__(self, other: object) -> object: ...
    @property
    def name(self) -> str: ...
    @property
    def value(self) -> int: ...

class EnergyBasedClusteringOptions:
    chains_to_ignore_: pyrosetta.rosetta.utility.vector1_unsigned_long
    cluster_by_: EBC_ClusterType
    cluster_cyclic_permutations_: bool
    cluster_radius_: float
    cst_files_: pyrosetta.rosetta.utility.vector1_std_string
    cyclic_: bool
    cyclic_permutation_offset_: int
    cyclic_symmetry_: int
    cyclic_symmetry_mirroring_: bool
    cyclic_symmetry_threshold_: float
    cyclic_symmetry_threshold_specified_: bool
    disulfide_positions_: pyrosetta.rosetta.utility.vector1_unsigned_long
    extra_rms_atoms_: pyrosetta.rosetta.utility.vector1_std_string
    homooligomer_swap_: bool
    limit_clusters_: int
    limit_structures_per_cluster_: int
    mutate_to_ala_: bool
    output_prefix_: str
    path_to_scores_file_: str
    perform_ABOXYZ_bin_analysis_: bool
    prerelax_: bool
    rebuild_all_in_dihedral_mode_: bool
    relax_rounds_: int
    residues_to_ignore_: pyrosetta.rosetta.utility.vector1_unsigned_long
    silent_output_: bool
    use_CB_: bool
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, initialize_from_options: bool) -> None: ...
    @overload
    def __init__(self, arg0: EnergyBasedClusteringOptions) -> None: ...
    def assign(self) -> EnergyBasedClusteringOptions: ...
    def clone(self) -> EnergyBasedClusteringOptions: ...
    @overload
    def initialize_from_global_options(self) -> None: ...
    @overload
    def initialize_from_global_options(self) -> void: ...

class EnergyBasedClusteringProtocol:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, options: EnergyBasedClusteringOptions) -> None: ...
    @overload
    def __init__(self, arg0: EnergyBasedClusteringProtocol) -> None: ...
    def assign(self) -> EnergyBasedClusteringProtocol: ...
    def clone(self) -> EnergyBasedClusteringProtocol: ...
    @overload
    def go(self) -> None: ...
    @overload
    def go(self) -> void: ...
    @overload
    def n_clusters_from_last_run(self) -> int: ...
    @overload
    def n_clusters_from_last_run(self) -> unsignedlong: ...
    @overload
    @staticmethod
    def register_options() -> None: ...
    @overload
    @staticmethod
    def register_options() -> void: ...
