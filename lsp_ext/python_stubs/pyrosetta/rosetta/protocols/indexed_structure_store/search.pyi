from typing import overload

class PairQueryExecutor:
    def __init__(self, arg0: StructurePairQuery) -> None: ...
    def execute(self, arg0: StructureDatabase) -> None: ...
    def execute_structure(self, arg0: int, arg1: StructureData) -> None: ...
    @property
    def query_results(self): ...

class PairQuerySummaryStatistics:
    def __init__(self, *args, **kwargs) -> None: ...
    @property
    def fragments_considered(self) -> int: ...
    @property
    def fragments_expanded(self) -> int: ...
    @property
    def pairs_aligned(self) -> int: ...
    @property
    def pairs_considered(self) -> int: ...
    @property
    def result_count(self) -> int: ...
    @property
    def structures_considered(self) -> int: ...

class SingleQueryExecutor:
    def __init__(self, arg0: StructureSingleQuery) -> None: ...
    def execute(self, arg0: StructureDatabase) -> None: ...
    def execute_structure(self, arg0: int, arg1: StructureData) -> None: ...
    @property
    def query_results(self): ...

class SingleQuerySummaryStatistics:
    def __init__(self, *args, **kwargs) -> None: ...
    @property
    def fragments_considered(self) -> int: ...
    @property
    def result_count(self) -> int: ...
    @property
    def structures_considered(self) -> int: ...

class StructureData:
    def __init__(self, *args, **kwargs) -> None: ...
    def get_fragment_centers_of_mass(self, *args, **kwargs): ...
    def get_fragment_indicies(self, *args, **kwargs): ...
    @property
    def chain_endpoints(self): ...
    @property
    def coordinate_buffer(self): ...
    @property
    def structure_offset(self) -> int: ...

class StructureDatabase:
    def __init__(self) -> None: ...
    def get_structure_data(self, *args, **kwargs): ...
    @overload
    def initialize(self, arg0, arg1, arg2) -> None: ...
    @overload
    def initialize(self, arg0) -> None: ...

class StructurePairQuery:
    @overload
    def __init__(self, arg0, arg1, arg2: float) -> None: ...
    @overload
    def __init__(self, arg0, arg1, arg2: float, arg3: int, arg4: int) -> None: ...
    @property
    def c_per_entry(self) -> int: ...
    @property
    def n_entry_a(self) -> int: ...
    @property
    def n_entry_b(self) -> int: ...
    @property
    def q_buffer_a(self): ...
    @property
    def q_buffer_b(self): ...
    @property
    def rmsd_tolerance(self) -> float: ...

class StructureSingleQuery:
    def __init__(self, arg0, arg1: float) -> None: ...
    @property
    def c_per_entry(self) -> int: ...
    @property
    def n_entry(self) -> int: ...
    @property
    def q_buffer(self): ...
    @property
    def rmsd_tolerance(self) -> float: ...
