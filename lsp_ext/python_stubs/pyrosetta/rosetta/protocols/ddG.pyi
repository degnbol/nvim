import pyrosetta.rosetta.utility
from typing import overload

class ddGData:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, filename: str) -> None: ...
    @overload
    def end(self) -> bool: ...
    @overload
    def end(self) -> bool: ...
    @overload
    def get_next_filenames(self) -> None: ...
    @overload
    def get_next_filenames(self) -> void: ...
    @overload
    def read_exp_data(self) -> float: ...
    @overload
    def read_exp_data(self) -> double: ...
    def read_mut_data(self) -> pyrosetta.rosetta.utility.vector1_core_pose_Pose: ...
    def read_wt_data(self) -> pyrosetta.rosetta.utility.vector1_core_pose_Pose: ...
