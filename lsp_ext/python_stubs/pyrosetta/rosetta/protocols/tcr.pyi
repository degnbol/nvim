class TCRloopRefine:
    @overload
    def __init__(self, tcrseq_info: TCRseqInfo) -> None: ...
    @overload
    def __init__(self, atcrseqs: TCRseqInfo.tcrsegs, btcrseqs: TCRseqInfo.tcrsegs, acdrposi: TCRseqInfo.tcrposi, bcdrposi: TCRseqInfo.tcrposi) -> None: ...
    @overload
    def __init__(self, arg0: TCRloopRefine) -> None: ...
    @overload
    def apply(self, pose_in: pyrosetta.rosetta.core.pose.Pose) -> None: ...
    @overload
    def apply(self, classcore) -> void: ...
    def assign(self) -> TCRloopRefine: ...
    def clone(self) -> TCRloopRefine: ...
    @overload
    def set_tcr_loop_model(self, tcrloopmodel: bool) -> None: ...
    @overload
    def set_tcr_loop_model(self, bool) -> void: ...
    @overload
    def tcr_loop_model(self) -> bool: ...
    @overload
    def tcr_loop_model(self) -> bool: ...

class TCRmodel:
