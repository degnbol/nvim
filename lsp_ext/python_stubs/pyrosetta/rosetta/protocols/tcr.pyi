        def __init__(self) -> None: ...
        def assign(self) -> TCRmodel.tmpltinfo: ...
    @overload
    def __init__(self, aseq: str, bseq: str) -> None: ...
    @overload
    def __init__(self, tcrinfo: TCRseqInfo) -> None: ...
    @overload
    def __init__(self, arg0: TCRmodel) -> None: ...
    def assign(self) -> TCRmodel: ...
    def atmplt(self, *args, **kwargs): ...
    def btmplt(self, *args, **kwargs): ...
    def clone(self) -> TCRmodel: ...
    @overload
    def set_use_gma_templates(self, gma: bool) -> None: ...
    @overload
    def set_use_gma_templates(self, bool) -> void: ...
    @overload
    def set_use_gmb_templates(self, gmb: bool) -> None: ...
    @overload
    def set_use_gmb_templates(self, bool) -> void: ...
    def tcr_graft_model(self) -> pyrosetta.rosetta.core.pose.Pose: ...
    def tcr_loop_model(self) -> pyrosetta.rosetta.core.pose.Pose: ...
    def tcr_model(self) -> pyrosetta.rosetta.core.pose.Pose: ...
    @overload
    def use_gma_templates(self) -> bool: ...
    @overload
    def use_gma_templates(self) -> bool: ...
    @overload
    def use_gmb_templates(self) -> bool: ...
    @overload
    def use_gmb_templates(self) -> bool: ...

class TCRseqInfo:
    class tcrposi:
        cap: pyrosetta.rosetta.protocols.antibody.grafting.CDR_Bounds
        cdr1: pyrosetta.rosetta.protocols.antibody.grafting.CDR_Bounds
        cdr2hv4: pyrosetta.rosetta.protocols.antibody.grafting.CDR_Bounds
        cdr3: pyrosetta.rosetta.protocols.antibody.grafting.CDR_Bounds
        @overload
        def __init__(self, arg0: TCRseqInfo.tcrposi) -> None: ...
        @overload
        def __init__(self) -> None: ...
        def assign(self) -> TCRseqInfo.tcrposi: ...

    class tcrsegs:
        cdr1: str
        cdr2: str
        cdr3: str
        fr: str
        gm: str
        truncdomain: str
        @overload
        def __init__(self, arg0: TCRseqInfo.tcrsegs) -> None: ...
        @overload
        def __init__(self) -> None: ...
        def assign(self) -> TCRseqInfo.tcrsegs: ...
    @overload
    def __init__(self, aseq: str, bseq: str) -> None: ...
    @overload
    def __init__(self, arg0: TCRseqInfo) -> None: ...
    def aaho_posi(self, *args, **kwargs): ...
    def aseq_posi(self, *args, **kwargs): ...
    def assign(self) -> TCRseqInfo: ...
    def atcr(self, *args, **kwargs): ...
    def baho_posi(self, *args, **kwargs): ...
    def bseq_posi(self, *args, **kwargs): ...
    def btcr(self, *args, **kwargs): ...
    def clone(self) -> TCRseqInfo: ...

