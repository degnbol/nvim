import pyrosetta.rosetta.std
from typing import overload

class ChromophoreDataReader:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: ChromophoreDataReader) -> None: ...
    def assign(self) -> ChromophoreDataReader: ...
    def clone(self) -> ChromophoreDataReader: ...
    @overload
    def create_residue_names_maps(self, instream: pyrosetta.rosetta.std.istream) -> None: ...
    @overload
    def create_residue_names_maps(self, std) -> void: ...
    def get_residue_names_map(self, residue_number: int) -> pyrosetta.rosetta.std.map_std_string_std_string: ...
    @overload
    def initialize_from_file(self, filename: str) -> None: ...
    @overload
    def initialize_from_file(self, conststd) -> void: ...
    def map_for_residue_exists(self, residue_number: int) -> bool: ...
    @overload
    def number_of_residues(self) -> int: ...
    @overload
    def number_of_residues(self) -> unsignedlong: ...

class ReadResidueCoordinatesFromPDB:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: ReadResidueCoordinatesFromPDB) -> None: ...
    def assign(self) -> ReadResidueCoordinatesFromPDB: ...
    def clone(self) -> ReadResidueCoordinatesFromPDB: ...
    @overload
    def coordinates_exist(self, resnum: int, chain_name: str) -> bool: ...
    @overload
    def coordinates_exist(self, constint, constchar) -> bool: ...
    @overload
    def number_of_residues(self) -> int: ...
    @overload
    def number_of_residues(self) -> unsignedlong: ...
