import pyrosetta.rosetta.utility
from typing import overload

class SS_predictor:
    @overload
    def __init__(self, type: str) -> None: ...
    @overload
    def __init__(self, arg0: SS_predictor) -> None: ...
    def assign(self) -> SS_predictor: ...
    def predict_ss(self, fasta: str) -> pyrosetta.rosetta.utility.vector1_utility_vector1_double_t: ...

@overload
def get_label(ss_pred_pos: pyrosetta.rosetta.utility.vector1_double) -> str: ...
@overload
def get_label(constclassutility) -> char: ...
@overload
def get_prob(wanted_ss: str, ss_pred_pos: pyrosetta.rosetta.utility.vector1_double) -> float: ...
@overload
def get_prob(char, constclassutility) -> double: ...
