from typing import overload

class InputArchiveBase:
    @overload
    def __init__(self, arg0: InputArchiveBase) -> None: ...
    @overload
    def __init__(self) -> None: ...
    def assign(self) -> InputArchiveBase: ...

class OutputArchiveBase:
    @overload
    def __init__(self, arg0: OutputArchiveBase) -> None: ...
    @overload
    def __init__(self) -> None: ...
    def assign(self) -> OutputArchiveBase: ...
