import typing
from typing import overload

class Matrix_double_t:
    @overload
    def __init__(self, nRows: int, nCols: int) -> None: ...
    @overload
    def __init__(self, nRows: int, nCols: int, val: float) -> None: ...
    @overload
    def __init__(self, arg0: Matrix_double_t) -> None: ...
    @overload
    def __init__(self, arg0: Matrix_double_t) -> None: ...
    def assign(self, other: Matrix_double_t) -> Matrix_double_t: ...
    @overload
    def getCol(self, i: int, col: Vector_double_t) -> None: ...
    @overload
    def getCol(self, unsignedint, classRDNumeric) -> void: ...
    def getData(self) -> float: ...
    @overload
    def getDataSize(self) -> int: ...
    @overload
    def getDataSize(self) -> unsignedint: ...
    @overload
    def getRow(self, i: int, row: Vector_double_t) -> None: ...
    @overload
    def getRow(self, unsignedint, classRDNumeric) -> void: ...
    def getVal(self, i: int, j: int) -> float: ...
    @overload
    def numCols(self) -> int: ...
    @overload
    def numCols(self) -> unsignedint: ...
    @overload
    def numRows(self) -> int: ...
    @overload
    def numRows(self) -> unsignedint: ...
    def setVal(self, i: int, j: int, val: float) -> None: ...
    def transpose(self, transpose: Matrix_double_t) -> Matrix_double_t: ...
    def __iadd__(self, other: Matrix_double_t) -> Matrix_double_t: ...
    def __imul__(self, scale: float) -> Matrix_double_t: ...
    def __isub__(self, other: Matrix_double_t) -> Matrix_double_t: ...
    def __itruediv__(self, scale: float) -> Matrix_double_t: ...

class SquareMatrix_double_t(Matrix_double_t):
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, N: int) -> None: ...
    @overload
    def __init__(self, N: int, val: float) -> None: ...
    @overload
    def __init__(self, arg0: SquareMatrix_double_t) -> None: ...
    @overload
    def __init__(self, arg0: SquareMatrix_double_t) -> None: ...
    def assign(self, other: Matrix_double_t) -> Matrix_double_t: ...
    @overload
    def getCol(self, i: int, col: Vector_double_t) -> None: ...
    @overload
    def getCol(self, unsignedint, classRDNumeric) -> void: ...
    def getData(self) -> float: ...
    @overload
    def getDataSize(self) -> int: ...
    @overload
    def getDataSize(self) -> unsignedint: ...
    @overload
    def getRow(self, i: int, row: Vector_double_t) -> None: ...
    @overload
    def getRow(self, unsignedint, classRDNumeric) -> void: ...
    def getVal(self, i: int, j: int) -> float: ...
    @overload
    def numCols(self) -> int: ...
    @overload
    def numCols(self) -> unsignedint: ...
    @overload
    def numRows(self) -> int: ...
    @overload
    def numRows(self) -> unsignedint: ...
    def setVal(self, i: int, j: int, val: float) -> None: ...
    def transpose(self, transpose: Matrix_double_t) -> Matrix_double_t: ...
    def transposeInplace(self) -> SquareMatrix_double_t: ...
    def __iadd__(self, other: Matrix_double_t) -> Matrix_double_t: ...
    @overload
    def __imul__(self, scale: float) -> SquareMatrix_double_t: ...
    @overload
    def __imul__(self, B: SquareMatrix_double_t) -> SquareMatrix_double_t: ...
    @overload
    def __imul__(self, scale: float) -> Matrix_double_t: ...
    def __isub__(self, other: Matrix_double_t) -> Matrix_double_t: ...
    def __itruediv__(self, scale: float) -> Matrix_double_t: ...

class Vector_double_t:
    @overload
    def __init__(self, N: int) -> None: ...
    @overload
    def __init__(self, N: int, val: float) -> None: ...
    @overload
    def __init__(self, arg0: Vector_double_t) -> None: ...
    def assign(self, other: Vector_double_t) -> Vector_double_t: ...
    @overload
    def dotProduct(self, other: Vector_double_t) -> float: ...
    @overload
    def dotProduct(self, constclassRDNumeric) -> double: ...
    def getData(self) -> float: ...
    @overload
    def getVal(self, i: int) -> float: ...
    @overload
    def getVal(self, unsignedint) -> double: ...
    @overload
    def largestAbsValId(self) -> int: ...
    @overload
    def largestAbsValId(self) -> unsignedint: ...
    @overload
    def largestValId(self) -> int: ...
    @overload
    def largestValId(self) -> unsignedint: ...
    @overload
    def normL1(self) -> float: ...
    @overload
    def normL1(self) -> double: ...
    @overload
    def normL2(self) -> float: ...
    @overload
    def normL2(self) -> double: ...
    @overload
    def normL2Sq(self) -> float: ...
    @overload
    def normL2Sq(self) -> double: ...
    @overload
    def normLinfinity(self) -> float: ...
    @overload
    def normLinfinity(self) -> double: ...
    @overload
    def normalize(self) -> None: ...
    @overload
    def normalize(self) -> void: ...
    @overload
    def setToRandom(self) -> None: ...
    @overload
    def setToRandom(self, seed: int) -> None: ...
    @overload
    def setToRandom(self, unsignedint) -> void: ...
    @overload
    def setVal(self, i: int, val: float) -> None: ...
    @overload
    def setVal(self, unsignedint, double) -> void: ...
    @overload
    def size(self) -> int: ...
    @overload
    def size(self) -> unsignedint: ...
    @overload
    def smallestValId(self) -> int: ...
    @overload
    def smallestValId(self) -> unsignedint: ...
    def __getitem__(self, i: int) -> float: ...
    def __iter__(self) -> typing.Iterator[float]: ...
    def __iadd__(self, other: Vector_double_t) -> Vector_double_t: ...
    def __imul__(self, scale: float) -> Vector_double_t: ...
    def __isub__(self, other: Vector_double_t) -> Vector_double_t: ...
    def __itruediv__(self, scale: float) -> Vector_double_t: ...
