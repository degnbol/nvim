import pyrosetta.rosetta.numeric
import pyrosetta.rosetta.std
import pyrosetta.rosetta.utility
from typing import overload

class Permute:
    @overload
    def __init__(self, x: Triple) -> None: ...
    @overload
    def __init__(self, arg0: Permute) -> None: ...
    def Member(self, i: int) -> Triple: ...
    @overload
    def Number(self) -> int: ...
    @overload
    def Number(self) -> unsignedlong: ...
    def assign(self) -> Permute: ...

class QuatDBMetadata:
    N: int
    cover: float
    delta: float
    name: str
    radius: float
    @overload
    def __init__(self, _name: str, _NN: int, _radius: float, _cover: float, _delta: float) -> None: ...
    @overload
    def __init__(self, arg0: QuatDBMetadata) -> None: ...
    def assign(self) -> QuatDBMetadata: ...

class QuatSet:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: QuatSet) -> None: ...
    @overload
    def Add(self, q: Quaternion) -> None: ...
    @overload
    def Add(self, q: Quaternion, w: float) -> None: ...
    @overload
    def Add(self, constclassbasic, double) -> void: ...
    @overload
    def Clear(self) -> None: ...
    @overload
    def Clear(self) -> void: ...
    @overload
    def Number(self) -> int: ...
    @overload
    def Number(self) -> unsignedlong: ...
    def Orientation(self, i: int) -> Quaternion: ...
    @overload
    def Print(self, s: pyrosetta.rosetta.std.ostream) -> None: ...
    @overload
    def Print(self, s: pyrosetta.rosetta.std.ostream, euler: bool) -> None: ...
    @overload
    def Print(self, s: pyrosetta.rosetta.std.ostream, euler: bool, prec: int) -> None: ...
    @overload
    def Weight(self, i: int) -> float: ...
    @overload
    def Weight(self, unsignedlong) -> double: ...
    def assign(self) -> QuatSet: ...

class Quaternion:
    w: float
    x: float
    y: float
    z: float
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, ww: float) -> None: ...
    @overload
    def __init__(self, ww: float, xx: float) -> None: ...
    @overload
    def __init__(self, ww: float, xx: float, yy: float) -> None: ...
    @overload
    def __init__(self, ww: float, xx: float, yy: float, zz: float) -> None: ...
    @overload
    def __init__(self, arg0: Quaternion) -> None: ...
    @overload
    def Canonicalize(self) -> None: ...
    @overload
    def Canonicalize(self) -> void: ...
    @overload
    def Normalize(self) -> None: ...
    @overload
    def Normalize(self) -> void: ...
    @overload
    def Print(self, s: pyrosetta.rosetta.std.ostream) -> None: ...
    @overload
    def Print(self, std) -> void: ...
    @overload
    def PrintEuler(self, s: pyrosetta.rosetta.std.ostream) -> None: ...
    @overload
    def PrintEuler(self, std) -> void: ...
    def Times(self, q: Quaternion) -> Quaternion: ...
    def euler(self) -> pyrosetta.rosetta.numeric.xyzVector_double_t: ...
    def rotation_matrix(self) -> pyrosetta.rosetta.numeric.xyzMatrix_double_t: ...

class QuaternionGrid:
    @overload
    def __init__(self, name: str, _in: pyrosetta.rosetta.std.istream) -> None: ...
    @overload
    def __init__(self, arg0: QuaternionGrid) -> None: ...
    def assign(self) -> QuaternionGrid: ...
    @overload
    def maxrad(self) -> float: ...
    @overload
    def maxrad(self) -> double: ...
    @overload
    def num_samples(self) -> int: ...
    @overload
    def num_samples(self) -> long: ...
    @overload
    def print(self) -> None: ...
    @overload
    def print(self) -> void: ...
    def quaternion(self, i: int) -> Quaternion: ...
    @overload
    def weight(self, i: int) -> float: ...
    @overload
    def weight(self, long) -> double: ...

class QuaternionGridManager(pyrosetta.rosetta.utility.SingletonBase_basic_sampling_orientations_QuaternionGridManager_t):
    def __init__(self, *args, **kwargs) -> None: ...
    def request_by_name(self, name: str) -> QuaternionGrid: ...
    def request_by_radius(self, target_radius: float) -> QuaternionGrid: ...
    def request_by_size(self, target_size: int) -> QuaternionGrid: ...

class Triple:
    a: int
    b: int
    c: int
    @overload
    def __init__(self, aa: int, bb: int, cc: int) -> None: ...
    @overload
    def __init__(self, arg0: Triple) -> None: ...
