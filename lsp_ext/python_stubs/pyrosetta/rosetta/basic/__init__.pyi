class Emitter:
    def __init__(self, out: pyrosetta.rosetta.std.ostream) -> None: ...
    @overload
    def depth(self) -> int: ...
    @overload
    def depth(self) -> int: ...
    @overload
    def end(self) -> None: ...
    @overload
    def end(self, desired_depth: int) -> None: ...
    @overload
    def end(self, unsignedlong) -> void: ...
    @overload
    def end_list(self) -> None: ...
    @overload
    def end_list(self) -> void: ...
    @overload
    def end_map(self) -> None: ...
    @overload
    def end_map(self) -> void: ...
    @overload
    def flush(self) -> None: ...
    @overload
    def flush(self) -> void: ...
    @overload
    def set_indent(self, num_spaces: int) -> None: ...
    @overload
    def set_indent(self, int) -> void: ...
    @overload
    def start_doc(self) -> None: ...
    @overload
    def start_doc(self) -> void: ...
    @overload
    def start_list(self) -> None: ...
    @overload
    def start_list(self, indent: bool) -> None: ...
    @overload
    def start_list(self, bool) -> void: ...
    @overload
    def start_list(self, label: str) -> None: ...
    @overload
    def start_list(self, label: str, indent: bool) -> None: ...
    @overload
    def start_list(self, conststd, bool) -> void: ...
    @overload
    def start_list(self, label: str) -> None: ...
    @overload
    def start_list(self, label: str, indent: bool) -> None: ...
    @overload
    def start_map(self) -> None: ...
    @overload
    def start_map(self, indent: bool) -> None: ...
    @overload
    def start_map(self, bool) -> void: ...
    @overload
    def start_map(self, label: str) -> None: ...
    @overload
    def start_map(self, label: str, indent: bool) -> None: ...
    @overload
    def start_map(self, conststd, bool) -> void: ...
    @overload
    def start_map(self, label: str) -> None: ...
    @overload
    def start_map(self, label: str, indent: bool) -> None: ...

class ExecutionResult:
    output: str
    result: int
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: ExecutionResult) -> None: ...
    def assign(self) -> ExecutionResult: ...

