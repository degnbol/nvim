import pyrosetta.rosetta.basic
from typing import overload

class Timer:
    @overload
    def __init__(self, tag: str) -> None: ...
    @overload
    def __init__(self, t: pyrosetta.rosetta.basic.Tracer.TracerProxy) -> None: ...
    @overload
    def __init__(self, t: pyrosetta.rosetta.basic.Tracer.TracerProxy, tag: str) -> None: ...
    @overload
    def __init__(self) -> None: ...
    @overload
    def GetTime(self) -> float: ...
    @overload
    def GetTime(self) -> double: ...
    @overload
    def Report(self) -> None: ...
    @overload
    def Report(self, tag: str) -> None: ...
    @overload
    def Reset(self) -> None: ...
    @overload
    def Reset(self) -> void: ...

class float4:
    w: float
    x: float
    y: float
    z: float
    def __init__(self) -> None: ...
