import pyrosetta.rosetta.cppdb
from typing import overload

class InsertGenerator:
    @overload
    def __init__(self, table_name: str) -> None: ...
    @overload
    def __init__(self, arg0: InsertGenerator) -> None: ...
    @overload
    def add_column(self, column_name: str) -> None: ...
    @overload
    def add_column(self, conststd) -> void: ...
    def assign(self) -> InsertGenerator: ...
    @overload
    def write_to_database(self, db_session) -> None: ...
    @overload
    def write_to_database(self, classstd) -> void: ...
    @overload
    def write_to_database(self, db_session, last_sequence_id: int, sequence_name: str) -> None: ...

class RowDataBase:
    @overload
    def __init__(self, column_name: str) -> None: ...
    @overload
    def __init__(self, arg0: RowDataBase) -> None: ...
    def assign(self) -> RowDataBase: ...
    @overload
    def bind_data(self, index: int, statement: pyrosetta.rosetta.cppdb.statement) -> None: ...
    @overload
    def bind_data(self, unsignedlong, classcppdb) -> void: ...
    def get_column_name(self) -> str: ...
