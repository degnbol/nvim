from typing import overload

class Base:
    int_value_: int
    string_value_: str
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: Base) -> None: ...
    @overload
    def __init__(self, arg0: Base) -> None: ...
    def assign(self) -> Base: ...
    @overload
    def foo_int(self, i: int) -> None: ...
    @overload
    def foo_int(self, int) -> void: ...
    @overload
    def foo_string(self, s: str) -> None: ...
    @overload
    def foo_string(self, std) -> void: ...
    @overload
    def foo_value(self, v: Value) -> None: ...
    @overload
    def foo_value(self, classutility) -> void: ...
    @overload
    def foo_value_sp(self, v: Value) -> None: ...
    @overload
    def foo_value_sp(self, classstd) -> void: ...

class OverloadTest:
    value_: Value
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: OverloadTest) -> None: ...
    def assign(self) -> OverloadTest: ...
    @overload
    def pure_test_p(self, v: Value) -> None: ...
    @overload
    def pure_test_p(self, classutility) -> void: ...
    @overload
    def pure_test_ref(self, v: Value) -> None: ...
    @overload
    def pure_test_ref(self, classutility) -> void: ...
    @overload
    def self_pure_test_virtual_p(self) -> None: ...
    @overload
    def self_pure_test_virtual_p(self) -> void: ...
    @overload
    def self_pure_test_virtual_ref(self) -> None: ...
    @overload
    def self_pure_test_virtual_ref(self) -> void: ...
    @overload
    def self_test_virtual_p(self) -> None: ...
    @overload
    def self_test_virtual_p(self) -> void: ...
    @overload
    def self_test_virtual_ref(self) -> None: ...
    @overload
    def self_test_virtual_ref(self) -> void: ...
    @overload
    def test_p(self, v: Value) -> None: ...
    @overload
    def test_p(self, classutility) -> void: ...
    @overload
    def test_ref(self, v: Value) -> None: ...
    @overload
    def test_ref(self, classutility) -> void: ...

class PyExitCallback:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: PyExitCallback) -> None: ...
    @overload
    def __init__(self, arg0: PyExitCallback) -> None: ...
    def assign(self) -> PyExitCallback: ...
    @overload
    def exit_callback(self) -> None: ...
    @overload
    def exit_callback(self) -> void: ...
    @overload
    @staticmethod
    def get_static_int() -> int: ...
    @overload
    @staticmethod
    def get_static_int() -> int: ...
    @staticmethod
    def get_static_string() -> str: ...
    @staticmethod
    def get_static_string_const() -> str: ...
    @overload
    @staticmethod
    def set_PyExitCallBack(exit_callback_object: PyExitCallback) -> None: ...
    @overload
    @staticmethod
    def set_PyExitCallBack(classstd) -> void: ...

class Value:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, s: str) -> None: ...
    @overload
    def __init__(self, arg0: Value) -> None: ...
    def assign(self) -> Value: ...
    @overload
    def s(self) -> str: ...
    @overload
    def s(self, s: str) -> None: ...
    @overload
    def s(self, conststd) -> void: ...

def foo_all(b: Base, i: int, v: Value, s: str) -> None: ...
@overload
def foo_all_sp(b: Base, i: int, v: Value, s: str) -> None: ...
@overload
def foo_all_sp(classstd, int, classutility, std) -> void: ...
