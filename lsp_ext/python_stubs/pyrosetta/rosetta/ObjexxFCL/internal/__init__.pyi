import pyrosetta.rosetta.ObjexxFCL
from . import ObserverMediator as ObserverMediator
from typing import overload

class InitializerSentinel:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: InitializerSentinel) -> None: ...

class ObserverGraph:
    @overload
    def __init__(self, s: pyrosetta.rosetta.ObjexxFCL.Observer) -> None: ...
    @overload
    def __init__(self, arg0: ObserverGraph) -> None: ...
    def assign(self) -> ObserverGraph: ...
    @overload
    def empty(self) -> bool: ...
    @overload
    def empty(self) -> bool: ...
    def pop(self) -> pyrosetta.rosetta.ObjexxFCL.Observer: ...
    def push(self, s_root: pyrosetta.rosetta.ObjexxFCL.Observer, s: pyrosetta.rosetta.ObjexxFCL.Observer) -> bool: ...

class ProxySentinel:
    @overload
    def __init__(self) -> None: ...
    @overload
    def __init__(self, arg0: ProxySentinel) -> None: ...
